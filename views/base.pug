doctype html
html
  head
    block head
      meta(charset='UTF-8')
      meta(name='viewport' content='width=device-width, initial-scale=1.0')
      link(rel='stylesheet' href='/css/style.css')
      link(rel='stylesheet' href='/css/chat.css')
      link(rel='stylesheet' href='/css/tourManagement.css')
      link(rel='stylesheet' href='/css/userManagement.css')
      link(rel='stylesheet' href='/css/bookingManagement.css')
      link(rel='stylesheet' href='/css/bookingDetail.css')
      link(rel='stylesheet' href='/css/bookingForm.css')
      link(rel='stylesheet' href='/css/reviewManagement.css')
      link(rel='stylesheet' href='/css/bookingSuccess.css')
      link(rel='stylesheet' href='/css/bookingInvoice.css')
      link(rel='stylesheet' href='/css/reviewModal.css')
      link(rel='stylesheet' href='/css/myTours.css')
      link(rel='stylesheet' href='/css/myBilling.css')
      link(rel='stylesheet' href='/css/myReviews.css')
      link(rel='stylesheet' href='/css/dashboard.css')
      link(rel='shortcut icon' type='image/png' href='/img/favicon.png')
      link(rel='stylesheet' href='https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;700&display=swap')
      link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
      title LLK Travel | #{title}
      block styles
  body
    // HEADER
    include _header
        
    // CONTENT
    block content

    // FOOTER
    include _footer

    // ========== CHAT NỔI USER ==========
    if user && user.role === 'user'
      button#chat-float.chat-floating-btn
        i.fas.fa-comments
      .chat-popup.hidden#chat-popup
        .chat-header
          h4 Chat với Admin
          button.close-btn &times;
        #chat-body
        form#chat-user-form
          input#chat-user-input(type='text', placeholder='Nhập tin nhắn...')
          button(type='submit') Gửi

      // Socket và script chat cho user
      script(src="https://cdn.socket.io/4.7.2/socket.io.min.js")
      script(src="/js/chatUser.js")
      script.
        window.userId = "#{user._id}";
        window.userName = "#{user.name}";

    // ========== CHAT ADMIN (NẾU CẦN THÊM SAU) ==========
    if user && user.role === 'admin'
      script(src="https://cdn.socket.io/4.7.2/socket.io.min.js")
      script(src="/js/chatAdmin.js")
      script.
        window.userId = "#{user._id}";
        window.userName = "#{user.name}";

    // ========== SCRIPT CHUNG ==========
    script(src='https://cdn.jsdelivr.net/npm/chart.js')
    script(src='/dist/index.js')
    
    block scripts
