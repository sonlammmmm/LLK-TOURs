doctype html
html
  head
    block head
      meta(charset='UTF-8')
      meta(name='viewport' content='width=device-width, initial-scale=1.0')
      link(rel='stylesheet' href='/css/style.css')
      link(rel='stylesheet' href='/css/userPortal.css')
      link(rel='stylesheet' href='/css/userManagement.css')
      link(rel='stylesheet' href='/css/bookingManagement.css')
      link(rel='stylesheet' href='/css/bookingDetail.css')
      link(rel='stylesheet' href='/css/bookingForm.css')
      link(rel='stylesheet' href='/css/reviewManagement.css')
      link(rel='stylesheet' href='/css/bookingSuccess.css')
      link(rel='stylesheet' href='/css/dashboard.css')
      link(rel='stylesheet' href='/css/admin.css')
      link(rel='stylesheet' href='/css/adminChat.css')
      link(rel='shortcut icon' type='image/png' href='/img/favicon.png')
      link(rel='stylesheet' href='https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;700&display=swap')
      link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
      title LLK Travel | #{title}
      block styles
  body(class= hideHeader ? 'llk-admin-body' : '')
    div.alert-container
    // HEADER
    if !hideHeader
      include _header
        
    // CONTENT
    block content

    // FOOTER
    if !hideFooter
      include _footer

    // ========== NÚT CHAT NỔI CHO USER ==========
    if user && user.role === 'user'
      a#chat-float.chat-floating-btn(href='/chat' title='Chat với Admin')
        i.fas.fa-comments

    // ========== SCRIPT CHUNG ==========
    script(src='https://cdn.jsdelivr.net/npm/chart.js')
    script(src='/dist/index.js')
    
    // ========== SOCKET.IO & CHAT SCRIPTS ==========
    if user
      //- Đặt biến global TRƯỚC khi load bất kỳ script nào
      script.
        window.userId = '#{user._id.toString()}';
        window.userName = '#{user.name}';
        window.userRole = '#{user.role}';
      
      //- Load Socket.IO (chỉ khi cần - sẽ được check trong page-specific scripts)
      script(src="https://cdn.socket.io/4.7.2/socket.io.min.js")
    
    block scripts
