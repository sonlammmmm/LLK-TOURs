extends base
include _userPortalMenu

block content
  main.main.user-portal-instance
    section.user-portal
      +userPortalMenu('promotions')
      .user-portal__content
        .user-portal__content-heading
          h2.heading-secondary Mã khuyến mãi riêng cho bạn
          p Tận dụng voucher để nhận ưu đãi mới nhất từ LLK Travel mỗi khi đặt tour.

        if !promotions || promotions.length === 0
          .promo-empty
            p Chưa có mã khuyến mãi nào được cấp cho tài khoản này.
        else
          .promo-cards
            each assignment in promotions
              .promo-card
                .promo-card__header
                  span.promo-card__code= assignment.code || assignment.promotion.code
                  span.badge.badge--neutral= assignment.promotion.discountType === 'percent' ? `${assignment.promotion.discountValue}%` : `${assignment.promotion.discountValue.toLocaleString('vi-VN')} đ`
                p.promo-card__title= assignment.promotion.name
                if assignment.promotion.description
                  p.promo-card__desc= assignment.promotion.description
                ul.promo-card__meta
                  li
                    strong Hạn dùng:
                    |  #{assignment.expiresAt ? new Date(assignment.expiresAt).toLocaleDateString('vi-VN') : (assignment.promotion.endDate ? new Date(assignment.promotion.endDate).toLocaleDateString('vi-VN') : 'Không giới hạn')}
                  li
                    strong Lượt dùng:
                    |  #{assignment.usageCount || 0}/#{assignment.usageLimit || assignment.promotion.perUserLimit || 1}
                button.btn.btn--small.btn--blue.btn-copy-code(data-code=assignment.code || assignment.promotion.code) Sao chép mã

block scripts
  script(src='/js/myPromotions.js', type='module')
