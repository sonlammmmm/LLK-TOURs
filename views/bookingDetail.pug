extends adminLayout

block adminContent
  .llk-admin-topbar
    .llk-admin-topbar__left
      h1.llk-admin-topbar__title Chi tiết đặt tour
      p.llk-admin-topbar__subtitle Mã đặt tour: ##{booking.id.slice(-8).toUpperCase()}
    .llk-admin-topbar__right
      a.btn.btn--ghost(href='/admin/bookings') ← Quay lại danh sách

  section.llk-admin-panel
    .llk-admin-detail-grid
      .llk-admin-detail-card
        h3.heading-tertiary Thông tin tour
        .booking-detail__item
          span.booking-detail__label Tour:
          span.booking-detail__value
            a(href=`/tour/${booking.tour.slug}`, target='_blank')= booking.tour.name
        if booking.tour.startDates && booking.tour.startDates.length > 0
          .booking-detail__item
            span.booking-detail__label Ngày khởi hành:
            span.booking-detail__value= booking.startDate ? new Date(booking.startDate).toLocaleDateString('vi-VN') : new Date(booking.tour.startDates[0]).toLocaleDateString('vi-VN')
        .booking-detail__item
          span.booking-detail__label Thời gian:
          span.booking-detail__value= booking.tour.duration ? `${booking.tour.duration} ngày` : 'Chưa xác định'
        .booking-detail__item
          span.booking-detail__label Số lượng:
          span.booking-detail__value= `${booking.participants || 1} người`
        if booking.services && booking.services.length
          .booking-detail__item
            span.booking-detail__label Dịch vụ thêm:
            span.booking-detail__value
              ul.booking-detail__services
                each service in booking.services
                  li #{service.name} x #{service.quantity} - #{(service.total || 0).toLocaleString('vi-VN')} ₫
        if booking.discountAmount && booking.discountAmount > 0
          .booking-detail__item
            span.booking-detail__label Giảm giá:
            span.booking-detail__value= `- ${(booking.discountAmount || 0).toLocaleString('vi-VN')} ₫`
      .llk-admin-detail-card
        h3.heading-tertiary Thông tin người đặt
        .booking-detail__user
          img.booking-detail__user-img(src=`/img/users/${booking.user.photo}`, alt=`${booking.user.name}`)
          .booking-detail__user-info
            .booking-detail__item
              span.booking-detail__label Tên:
              span.booking-detail__value= booking.user.name
            .booking-detail__item
              span.booking-detail__label Email:
              span.booking-detail__value= booking.user.email
            .booking-detail__item
              span.booking-detail__label Vai trò:
              span.booking-detail__value
                span(class=`user-badge user-badge--${booking.user.role}`)= booking.user.role
      .llk-admin-detail-card
        h3.heading-tertiary Thông tin thanh toán
        .booking-detail__item
          span.booking-detail__label Giá/người:
          span.booking-detail__value= `${(booking.price / (booking.participants || 1)).toLocaleString('vi-VN')} VND`
        .booking-detail__item
          span.booking-detail__label Tổng tiền:
          span.booking-detail__value= `${booking.price.toLocaleString('vi-VN')} VND`
        .booking-detail__item
          span.booking-detail__label Trạng thái:
          span.booking-detail__value
            span(class=`booking-badge booking-badge--${booking.paid ? 'paid' : 'unpaid'}`)= booking.paid ? 'Đã thanh toán' : 'Chưa thanh toán'
        .booking-detail__item
          span.booking-detail__label Ngày đặt:
          span.booking-detail__value= new Date(booking.createdAt).toLocaleString('vi-VN')

    .booking-detail__actions
      if !booking.paid
        button.btn.btn--small.btn--green.btn-mark-paid(data-booking-id=`${booking.id}`) Đánh dấu đã thanh toán
      else
        button.btn.btn--small.btn--orange.btn-mark-unpaid(data-booking-id=`${booking.id}`) Đánh dấu chưa thanh toán
      a.btn.btn--small.btn--blue.btn-print-booking-invoice(href=`/booking-invoice/${booking.id}?print=true`, target='_blank', data-booking-id=`${booking.id}`) In hóa đơn
      button.btn.btn--small.btn--red.btn-delete-booking(data-booking-id=`${booking.id}`) Xóa đặt tour
