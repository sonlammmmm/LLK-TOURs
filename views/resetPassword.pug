extends base

block content
  main.main
    .login-form
      h2.heading-secondary.ma-bt-lg Đặt lại mật khẩu
      form.form.form--reset-password
        input#token(type='hidden', value=`${token}`)
        .form__group
          label.form__label(for='password') Mật khẩu mới
          input#password.form__input(type='password', placeholder='••••••••', required, minlength='8')
        .form__group.ma-bt-lg
          label.form__label(for='passwordConfirm') Xác nhận mật khẩu
          input#passwordConfirm.form__input(type='password', placeholder='••••••••', required, minlength='8')
        .form__group
          button.btn.btn--green Đặt lại mật khẩu
