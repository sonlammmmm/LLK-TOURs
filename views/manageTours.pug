extends adminLayout

block adminContent
  .llk-admin-topbar
    .llk-admin-topbar__left
      h1.llk-admin-topbar__title Quản lý tour
    .llk-admin-topbar__right
      a.btn.btn--small.btn--green(href='/admin/tours/new')
        svg(width='16' height='16')
          use(xlink:href='/img/icons.svg#icon-plus-circle')
        |  Tạo tour mới

  section.llk-admin-panel
    .llk-admin-panel__stats
      .llk-admin-stat-card
        span.llk-admin-stat-card__label Tổng số tour
        strong.llk-admin-stat-card__value #{tours.length}
      .llk-admin-stat-card
        span.llk-admin-stat-card__label Ngày khởi hành sắp tới
        strong.llk-admin-stat-card__value #{totalUpcomingDepartures}
      .llk-admin-stat-card
        span.llk-admin-stat-card__label Vé đã đặt
        strong.llk-admin-stat-card__value #{totalFutureBookings}

    .llk-admin-panel__toolbar
      input.llk-admin-panel__search(type='text', placeholder='Tìm tour theo tên...')

    if tours.length === 0
      p.llk-admin-empty Không có tour nào vừa được tạo.
    else
      .llk-admin-tour-grid
        each tour in tours
          article.llk-admin-tour-card
            .llk-admin-tour-card__media
              if tour.imageCover
                img.llk-admin-tour-card__image(src=`/img/tours/${tour.imageCover}`, alt=`${tour.name}`)
              else
                .llk-admin-tour-card__image--placeholder Chưa có hình
              span.llk-admin-tour-card__badge #{tour.duration} ngày
            .llk-admin-tour-card__body
              .llk-admin-tour-card__head
                h3.llk-admin-tour-card__title= tour.name
                if tour.isHidden
                  span.llk-admin-tour-card__status.text-danger Đang ẩn khỏi website
                .llk-admin-tour-card__actions
                  a.btn.btn--small.btn--blue(href=`/admin/tours/${tour._id}/edit`) Sửa
                  a.btn.btn--small.btn--green(href=`/tour/${tour.slug}`, target='_blank') Xem
                  if tour.hasTransactions
                    button.btn.btn--small.btn--ghost.btn-toggle-tour(type='button', data-tour-id=`${tour._id}`, data-hidden= tour.isHidden ? 'true' : 'false')= tour.isHidden ? 'Hiện trên web' : 'Ẩn khỏi web'
                  else
                    button.btn.btn--small.btn--red.btn-delete-tour(type='button', data-tour-id=`${tour._id}`) Xóa
              p.llk-admin-tour-card__summary= tour.summary || 'Chưa có mô tả'
              .llk-admin-tour-card__meta
                span
                  svg
                    use(xlink:href='/img/icons.svg#icon-dollar-sign')
                  | #{tour.price.toLocaleString('vi-VN')} VND
                span
                  svg
                    use(xlink:href='/img/icons.svg#icon-user')
                  | #{tour.maxGroupSize} khách
                span
                  svg
                    use(xlink:href='/img/icons.svg#icon-star')
                  | #{tour.ratingsAverage} (#{typeof tour.displayRatingsQuantity === 'number' ? tour.displayRatingsQuantity : (tour.ratingsQuantity || 0)})
                if tour.hasTransactions
                  span
                    svg
                      use(xlink:href='/img/icons.svg#icon-credit-card')
                    | #{tour.totalTransactions} giao dịch
              .llk-admin-tour-card__dates
                h4.llk-admin-tour-card__dates-title Ngày khởi hành đang hoạt động
                if tour.activeStartDates.length
                  ul.llk-admin-tour-card__dates-list
                    each date in tour.activeStartDates.slice(0, 3)
                      li.llk-admin-tour-card__date-item
                        span.llk-admin-tour-card__date #{date.dateFormatted}
                        span.llk-admin-tour-card__date-meta Đặt #{date.bookedSeats} vé · Còn #{date.availableSlots} slot
                  if tour.activeStartDates.length > 3
                    p.llk-admin-tour-card__more +#{tour.activeStartDates.length - 3} ngày khác
                else
                  p.llk-admin-tour-card__no-dates Chưa có ngày khởi hành mới.
              form.llk-admin-tour-card__quick-start(
                data-tour-id=`${tour._id}`
                data-max-size=`${tour.maxGroupSize}`
              )
                label(for=`quick-date-${tour._id}`) Thêm ngày khởi hành nhanh
                .llk-admin-tour-card__quick-start-row
                  input(type='date', required, id=`quick-date-${tour._id}`)
                  input(type='number', min='1', max=`${tour.maxGroupSize}`, placeholder=`${tour.maxGroupSize}`, aria-label='Số slot')
                  button.btn.btn--small.btn--blue(type='submit') Thêm
                small.help-text Slot mặc định = sức chứa nếu bạn bỏ trống.
