extends base
include _authShowcase

block content
  main.main.auth-page
    section.auth-layout
      .auth-panel
        .auth-panel__inner
          .auth-brand
            a.auth-brand__logo(href='/')
              img(src='/img/logo-blue.png' alt='LLK Travel logo')
            .auth-brand__text
              span LLK Travel
              small LƯU GIỮU - LẮNG ĐỌNG - KHÁM PHÁ
          h1.auth-panel__title Làm mới mật khẩu
          p.auth-panel__subtitle Nhập email đã đăng ký để nhận liên kết đặt lại mật khẩu. Chúng tôi sẽ gửi hướng dẫn nhanh chóng đến hộp thư của bạn.
          form.form.form--forgot-password
            .auth-field
              label.auth-field__label(for='email') Email của bạn
              .auth-field__input
                i.fa-regular.fa-envelope
                input#email(type='email', placeholder='ban@llk.travel', required)
            button.btn.auth-btn(type='submit')
              i.fa-solid.fa-paper-plane
              |  Gửi liên kết đặt lại
          .auth-meta
            span Nhớ mật khẩu rồi?
            a.auth-link(href='/login') Quay lại đăng nhập
      +authShowcase()
