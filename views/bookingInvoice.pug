extends base

block content
  - var hideFooter = true
  main.invoice-page
    section.invoice-wrapper
      - const startDateValue = booking.startDate ? new Date(booking.startDate).toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' }) : booking.tour.startDates[0].toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' })
      - const createdDateValue = new Date(booking.createdAt).toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' })
      - const baseTotal = booking.basePrice || booking.price || 0
      - const baseUnit = (baseTotal || 0) / (booking.participants || 1)
      - const servicesTotal = booking.servicesTotal || 0
      - const discountAmount = booking.discountAmount || 0
      - const totalValue = typeof booking.price === 'number' ? booking.price : Math.max(baseTotal + servicesTotal - discountAmount, 0)
      - const formattedTotal = `${totalValue.toLocaleString('vi-VN')} VND`
      - const backLink = user && user.role === 'admin' ? '/admin/bookings' : '/my-tours';
      .invoice-card-shell
        a.btn.btn--ghost.invoice-card-shell__btn(href=backLink)
          svg(width='20', height='20')
            use(xlink:href='/img/icons.svg#icon-arrow-left-circle')
          |  Quay lại
        .invoice-card
          .invoice-hero
            .invoice-hero__body
              .invoice-hero__title
                span.invoice-hero__code Mã: ##{booking.id.slice(-8).toUpperCase()}
                h2.heading-secondary= booking.tour.name
              .invoice-hero__meta
                span
                  strong Ngày đặt:
                  |  #{createdDateValue}
                span
                  strong Ngày khởi hành:
                  |  #{startDateValue}
                span
                  strong Số ngày:
                  |  #{booking.tour.duration} ngày
            .invoice-hero__total
              span.invoice-hero__total-label Tổng thanh toán
              span.invoice-hero__total-value= formattedTotal
          .invoice-content-grid
            .invoice-content-grid__main
              .invoice-table
                table
                  thead
                    tr
                      th Dịch vụ
                      th Đơn giá
                      th Số lượng
                      th Thành tiền
                  tbody
                    tr
                      td= booking.tour.name
                      td= `${baseUnit.toLocaleString('vi-VN')} VND`
                      td= booking.participants || 0
                      td= `${baseTotal.toLocaleString('vi-VN')} VND`
                    if booking.services && booking.services.length
                      each service in booking.services
                        tr
                          td= service.name
                          td= `${(service.price || 0).toLocaleString('vi-VN')} VND`
                          td= service.quantity
                          td= `${(service.total || 0).toLocaleString('vi-VN')} VND`
                  tfoot
                    if servicesTotal
                      tr
                        td(colspan='3') Tổng dịch vụ
                        td= `${servicesTotal.toLocaleString('vi-VN')} VND`
                    if discountAmount && discountAmount > 0
                      tr
                        td(colspan='3') Giảm giá
                        td= `- ${discountAmount.toLocaleString('vi-VN')} VND`
                    tr
                      td(colspan='3') Tổng thanh toán
                      td= formattedTotal
            .invoice-content-grid__sidebar
              .invoice-info-card
                h3.invoice-info-card__title Khách hàng
                .invoice-info-card__list
                  .invoice-info-card__item
                    span.label Tên
                    span.value= booking.user.name
                  .invoice-info-card__item
                    span.label Email
                    span.value= booking.user.email
              .invoice-info-card
                h3.invoice-info-card__title Tour & lịch
                .invoice-info-card__list
                  .invoice-info-card__item
                    span.label Tour
                    span.value= booking.tour.name
                  .invoice-info-card__item
                    span.label Ngày khởi hành
                    span.value= startDateValue
                  .invoice-info-card__item
                    span.label Thời gian
                    span.value= `${booking.tour.duration} ngày`
                  .invoice-info-card__item
                    span.label Số lượng người
                    span.value= booking.participants || 0
                  .invoice-info-card__item
                    span.label Đơn giá cơ bản
                    span.value= `${baseUnit.toLocaleString('vi-VN')} VND/người`
              .invoice-breakdown
                span.invoice-breakdown__title Tóm tắt chi phí
                .invoice-breakdown__item
                  span.invoice-breakdown__label Dịch vụ bổ sung
                  span.invoice-breakdown__value= `${servicesTotal.toLocaleString('vi-VN')} VND`
                .invoice-breakdown__item
                  span.invoice-breakdown__label Chiết khấu
                  span.invoice-breakdown__value= discountAmount > 0 ? `- ${discountAmount.toLocaleString('vi-VN')} VND` : '0 VND'
                .invoice-breakdown__item.invoice-breakdown__item--total
                  span.invoice-breakdown__label Thanh toán cuối
                  span.invoice-breakdown__value= formattedTotal
              .invoice-status-card
                .invoice-status-card__row
                  span.invoice-label Trạng thái:
                  span(class=`invoice-status-badge invoice-status-badge--${booking.paid ? 'paid' : 'unpaid'}`)= booking.paid ? 'Đã thanh toán' : 'Chưa thanh toán'
                .invoice-status-card__row
                  span.invoice-label Ngày tạo:
                  span.invoice-value= createdDateValue
        button.btn.btn--green.btn-print-invoice.invoice-card-shell__btn(type='button')
          svg(width='20', height='20')
            use(xlink:href='/img/icons.svg#icon-printer')
          |  In hóa đơn
