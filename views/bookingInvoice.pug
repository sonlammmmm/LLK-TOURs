extends base
include _userPortalMenu

block content
  main.main.user-portal-instance
    section.user-portal
      +userPortalMenu('billing')
      .user-portal__content
        .invoice-wrapper
          .invoice-card
            .invoice-header
              .invoice-logo
                img(src='/img/logo-white.png', alt='LLK Travel')
              .invoice-title
                h2.heading-secondary Hoá đơn
                .invoice-number Mã hoá đơn: ##{booking.id.slice(-8).toUpperCase()}

            .invoice-details
              .invoice-customer
                h3.invoice-subtitle Thông tin khách hàng
                .invoice-info
                  .invoice-info-item
                    span.invoice-label Tên:
                    span.invoice-value= booking.user.name
                  .invoice-info-item
                    span.invoice-label Email:
                    span.invoice-value= booking.user.email
              .invoice-booking
                h3.invoice-subtitle Thông tin đặt tour
                .invoice-info
                  .invoice-info-item
                    span.invoice-label Tour:
                    span.invoice-value= booking.tour.name
                  .invoice-info-item
                    span.invoice-label Ngày khởi hành:
                    span.invoice-value= booking.startDate ? new Date(booking.startDate).toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' }) : booking.tour.startDates[0].toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' })
                  .invoice-info-item
                    span.invoice-label Thời gian:
                    span.invoice-value= `${booking.tour.duration} ngày`
                  .invoice-info-item
                    span.invoice-label Số lượng người:
                    span.invoice-value= booking.participants

            .invoice-table
              - const baseTotal = booking.basePrice || booking.price;
              - const baseUnit = (baseTotal || 0) / (booking.participants || 1);
              table
                thead
                  tr
                    th Mã tour
                    th Đơn giá
                    th Số lượng
                    th Thành tiền
                tbody
                  tr
                    td= booking.tour.name
                    td= `${baseUnit.toLocaleString('vi-VN')} VND`
                    td= booking.participants
                    td= `${baseTotal.toLocaleString('vi-VN')} VND`
                  if booking.services && booking.services.length
                    each service in booking.services
                      tr
                        td= service.name
                        td= `${(service.price || 0).toLocaleString('vi-VN')} VND`
                        td= service.quantity
                        td= `${(service.total || 0).toLocaleString('vi-VN')} VND`
                tfoot
                  if booking.servicesTotal
                    tr
                      td(colspan='3') Tổng dịch vụ
                      td= `${booking.servicesTotal.toLocaleString('vi-VN')} VND`
                  if booking.discountAmount && booking.discountAmount > 0
                    tr
                      td(colspan='3') Giảm giá
                      td= `- ${(booking.discountAmount || 0).toLocaleString('vi-VN')} VND`
                  tr
                    td(colspan='3') Tổng thanh toán
                    td= `${booking.price.toLocaleString('vi-VN')} VND`

            .invoice-footer
              .invoice-status
                span.invoice-label Trạng thái:
                span(class=`invoice-status-badge invoice-status-badge--${booking.paid ? 'paid' : 'unpaid'}`)= booking.paid ? 'Đã thanh toán' : 'Chưa thanh toán'
              .invoice-date
                span.invoice-label Ngày đặt:
                span.invoice-value= new Date(booking.createdAt).toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' })

          .invoice-actions
            button.btn.btn--green.btn-print-invoice In hoá đơn
            a.btn.btn--blue(href='/my-tours') Quay lại
