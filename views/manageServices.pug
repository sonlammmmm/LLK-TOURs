extends adminLayout

block adminContent
  .llk-admin-topbar
    .llk-admin-topbar__left
      h1.llk-admin-topbar__title Quản lý dịch vụ
      p.llk-admin-topbar__subtitle Thiết lập các dịch vụ bổ sung để tăng trải nghiệm tour.
    .llk-admin-topbar__right
      a.btn.btn--small.btn--green(href='/admin/services/new')
        svg(width='16', height='16')
          use(xlink:href='/img/icons.svg#icon-plus-circle')
        |  Tạo dịch vụ mới

  section.llk-admin-panel.service-table(
    data-collection='.service-admin-card'
  )
    - const serviceList = Array.isArray(services) ? services : [];
    - const totalServices = serviceList.length;
    - const activeServices = serviceList.filter((s) => s.status === 'active').length;
    - const perPersonServices = serviceList.filter((s) => s.chargeType === 'per-person').length;

    .llk-admin-panel__stats.llk-admin-panel__stats--wide
      .llk-admin-stat-card
        span.llk-admin-stat-card__label Tổng dịch vụ
        strong.llk-admin-stat-card__value #{totalServices}
      .llk-admin-stat-card
        span.llk-admin-stat-card__label Đang hiển thị
        strong.llk-admin-stat-card__value #{activeServices}
      .llk-admin-stat-card
        span.llk-admin-stat-card__label Tính theo người
        strong.llk-admin-stat-card__value #{perPersonServices}

    if totalServices > 0
      .llk-admin-panel__toolbar
        input.llk-admin-panel__search.search-input(
          type='text'
          placeholder='Tìm kiếm dịch vụ...'
          aria-label='Tìm kiếm dịch vụ'
          data-collection-search
        )
        select.llk-admin-panel__filter.filter-status(
          data-collection-filter
          data-filter-field='status'
          aria-label='Lọc theo trạng thái'
        )
          option(value='') Tất cả trạng thái
          option(value='active') Đang hiển thị
          option(value='inactive') Đang ẩn
        select.llk-admin-panel__filter(
          data-collection-filter
          data-filter-field='charge'
          aria-label='Lọc theo hình thức tính phí'
        )
          option(value='') Tất cả hình thức tính phí
          option(value='per-person') Theo người
          option(value='per-booking') Theo lượt/booking
        p.count-display
          | Đang hiển thị 
          strong #{totalServices}
          |  trên tổng số 
          strong #{totalServices}
      p.no-data-message.llk-admin-empty.hidden Không tìm thấy dịch vụ phù hợp.

    if totalServices === 0
      p.llk-admin-empty Chưa có dịch vụ nào được cấu hình.
    else
      .llk-admin-card-grid
        each service in serviceList
          - const isActive = service.status === 'active';
          - const billingLabel = service.chargeType === 'per-person' ? 'Theo người' : 'Theo lượt/booking';
          - const searchText = `${service.name} ${service.shortDescription || ''} ${service.description || ''}`.toLowerCase();
          article.service-admin-card(
            data-status=service.status
            data-charge=service.chargeType
            data-visibility=service.visibility
            data-search=searchText
          )
            .service-admin-card__head
              .service-admin-card__title
                h3.service-admin-card__name= service.name
                if service.shortDescription
                  p.service-admin-card__desc= service.shortDescription
              span(class=`promo-card__badge ${isActive ? 'promo-card__badge--active' : 'promo-card__badge--inactive'}`)= isActive ? 'Đang hiển thị' : 'Đã tắt'
            .service-admin-card__price #{service.price.toLocaleString('vi-VN')} VND
            .service-admin-card__meta
              p
                strong Loại tính phí:
                |  #{billingLabel}
              p
                strong Hiển thị:
                |  #{service.visibility === 'public' ? 'Công khai' : 'Nội bộ'}
              p
                strong Thứ tự:
                |  #{service.displayOrder || 0}
            if service.allowMultiple || service.chargeType === 'per-person'
              .service-admin-card__chips
                if service.chargeType === 'per-person'
                  span.service-admin-card__chip Áp dụng theo số người
                if service.allowMultiple && service.chargeType === 'per-booking'
                  span.service-admin-card__chip Cho phép chọn nhiều lần
            .service-admin-card__actions
              button.btn.btn--small.btn--orange.btn-toggle-service(
                data-service-id=`${service.id}`
                data-next-status=`${service.status === 'active' ? 'inactive' : 'active'}`
              )= service.status === 'active' ? 'Ẩn dịch vụ' : 'Hiển thị'
              a.btn.btn--small.btn--blue(href=`/admin/services/${service.id}/edit`) Chỉnh sửa
              button.btn.btn--small.btn--red.btn-delete-service(data-service-id=`${service.id}`) Xóa
