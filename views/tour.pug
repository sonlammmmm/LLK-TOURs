extends base
include _reviewCard

block append head
  script(src='https://api.mapbox.com/mapbox-gl-js/v3.12.0/mapbox-gl.js')
  link(href='https://api.mapbox.com/mapbox-gl-js/v3.12.0/mapbox-gl.css' rel='stylesheet')

block content
  - const meta = tourStartMeta || {}
  - const bookingDateOptions = Array.isArray(meta.bookingDateOptions) ? meta.bookingDateOptions : []
  - const primaryBookingOption = meta.primaryBookingOption || null
  - const hasUpcomingStart = Boolean(meta.hasUpcomingStart)
  - const hasAvailableStart = Boolean(meta.hasAvailableStart)
  - const nextDateDisplay = meta.nextDateDisplay || 'Đang cập nhật'
  - const bookingHref = user && user.role === 'user' ? `/book-tour/${tour._id}` : '/login'
  - const contactMessage = `Tôi muốn hỏi về Tour ${tour.name}`
  - const userContactHref = user && user.role === 'user' ? `/chat?prefill=${encodeURIComponent(contactMessage)}` : '/login'
  - const totalStops = tour.locations && tour.locations.length ? tour.locations.length : 0
  - const galleryImages = Array.isArray(tour.images) ? tour.images : []
  - const ratingLabel = `${tour.ratingsAverage} / 5⭐ (${tour.ratingsQuantity} đánh giá)`
  - const ratingAverageRaw = typeof tour.ratingsAverage === 'number' ? tour.ratingsAverage : Number(tour.ratingsAverage)
  - const ratingAverageValue = Number.isFinite(ratingAverageRaw) ? ratingAverageRaw : 0
  - const ratingAverageRounded = Math.round(ratingAverageValue * 10) / 10
  - const ratingAverageDisplay = Number.isFinite(ratingAverageRounded) ? ratingAverageRounded.toFixed(1) : '0.0'
  - const ratingAverageStars = Math.min(5, Math.max(0, Math.round(ratingAverageValue)))
  - const allReviews = Array.isArray(tour.reviews) ? tour.reviews.slice() : []
  - const sortedReviews = allReviews.sort((a, b) => (b.rating || 0) - (a.rating || 0))
  - const maxInitialReviews = 9
  - const initialReviews = sortedReviews.slice(0, maxInitialReviews)
  - const extraReviews = sortedReviews.slice(maxInitialReviews)

  section.tour-hero
    .tour-hero__media
      img.tour-hero__img(src=`/img/tours/${tour.imageCover}`, alt=`${tour.name}`)
      .tour-hero__overlay
    .tour-hero__content
      span.tour-hero__eyebrow= tour.startLocation.description
      h1.tour-hero__title= tour.name
      p.tour-hero__summary= tour.summary
      .tour-hero__meta
        .tour-pill
          i.fas.fa-clock
          span= `${tour.duration} ngày`
        if hasUpcomingStart
          .tour-pill
            i.fas.fa-calendar-alt
            span= `Khởi hành: ${nextDateDisplay}`
        .tour-pill
          i.fas.fa-users
          span= `${tour.maxGroupSize} khách`
        .tour-pill
          i.fas.fa-star
          span= ratingLabel

  .quick-booking-floating
    .quick-booking
      span.quick-booking__eyebrow Đặt tour nhanh
      h3.quick-booking__price= `${tour.price.toLocaleString('vi-VN')} VNĐ/người`
      p.quick-booking__note= hasAvailableStart ? 'Giữ chỗ ngay để đồng hành trong chuyến đi sắp tới.' : (hasUpcomingStart ? 'Các lịch khởi hành sắp tới hiện đã kín chỗ. Liên hệ với concierge để được ưu tiên khi mở thêm.' : 'Hiện chưa có lịch khởi hành, hãy liên hệ để được cập nhật.')
      if hasAvailableStart
        label.quick-booking__label(for='quickBookingDate') Chọn ngày khởi hành
        div.quick-booking__control
          i.fas.fa-calendar-day
          select#quickBookingDate.quick-booking__select
            each dateOption in bookingDateOptions
              - const readable = dateOption.dateFormatted || new Date(dateOption.date).toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' })
              - const optionValue = dateOption.dateISO || new Date(dateOption.date).toISOString()
              option(value=optionValue selected=dateOption === primaryBookingOption)= readable
        a.btn.btn--green.quick-booking__btn(href=bookingHref data-booking-href=bookingHref) Đăng ký ngay
      else
        if hasUpcomingStart
          p.quick-booking__empty Các lịch khởi hành sắp tới hiện đã kín chỗ. Liên hệ với concierge để được hỗ trợ hoặc chờ thông báo mở chỗ.
        else
          p.quick-booking__empty Chúng tôi sẽ gửi thông tin lịch mới ngay khi có. Liên hệ với concierge để được hỗ trợ thêm.
        a.btn.btn--contact.quick-booking__btn(href=userContactHref)
          i.fas.fa-headset
          span Liên hệ với admin
      ul.quick-booking__info
        li
          i.fas.fa-check
          span Miễn phí huỷ trong 48h đầu tiên
        li
          i.fas.fa-shield
          span Thanh toán an toàn, bảo mật
        li
          i.fas.fa-phone
          span Hotline hỗ trợ 24/7

  main.tour-main
    .tour-layout
      section.tour-section
        span.tour-section__eyebrow Thông tin
        h2.heading-secondary Tổng quát hành trình này
        .tour-metrics
          .tour-metric
            span.tour-metric__label Thời lượng
            strong.tour-metric__value= `${tour.duration} ngày`
            span.tour-metric__meta= `${tour.duration - 1 || 1} đêm nghỉ dưỡng`
          .tour-metric
            span.tour-metric__label Khởi hành tiếp theo
            strong.tour-metric__value= nextDateDisplay
            span.tour-metric__meta= hasUpcomingStart ? 'Sẵn sàng nhận chỗ' : 'Đang cập nhật lịch trình'
          .tour-metric
            span.tour-metric__label Số chỗ
            strong.tour-metric__value= `${tour.maxGroupSize} khách`
            span.tour-metric__meta= 'Nhóm nhỏ đẳng cấp'
          .tour-metric
            span.tour-metric__label Đánh giá
            strong.tour-metric__value= `${tour.ratingsAverage}/5`
            span.tour-metric__meta= `${tour.ratingsQuantity} lượt đánh giá`

      section.tour-section
        h3.tour-section__title Về tour này
        - const paragraphs = tour.description ? tour.description.split('\n') : ['Chưa có mô tả cho tour này.']
        each paragraph in paragraphs
          p.tour-section__text= paragraph
        ul.tour-checklist
          li
            i.fas.fa-location-dot
            span= `Điểm khởi hành: ${tour.startLocation.description}`
          li
            i.fas.fa-mountain
            span= `Tổng số điểm tham quan: ${totalStops || 'Đang cập nhật'}`
          li
            i.fas.fa-user-tie
            span Hướng dẫn viên địa phương giàu kinh nghiệm đồng hành
          li
            i.fas.fa-shield-heart
            span Bảo hiểm du lịch & hỗ trợ 24/7

      section.tour-section.tour-map-wrapper
        h3.tour-section__title Bản đồ & lộ trình
        .tour-map-card
          .tour-map-card__map
            #map(data-locations=`${JSON.stringify(tour.locations || [])}`)
            .map-panel__legend
              span.map-badge
                i.fas.fa-map-marker-alt
                span= `${totalStops} điểm dừng`
              span.map-badge
                i.fas.fa-clock
                span= `${tour.duration} ngày`
              if hasUpcomingStart
                span.map-badge.map-badge--accent
                  i.fas.fa-calendar-day
                  span= nextDateDisplay
          .tour-map-card__details
            ul.tour-map-info
              li
                span.tour-map-info__label Điểm khởi hành
                strong.tour-map-info__value= tour.startLocation.description
                if tour.startLocation.address
                  span.tour-map-info__meta= tour.startLocation.address
            if totalStops
              ul.tour-map-info__timeline
                each location in tour.locations
                  li
                    span.tour-map-info__badge= location.day ? `Ngày ${location.day}` : 'Điểm dừng'
                    div
                      p.tour-map-info__title= location.description
            else
              p.map-timeline__empty Lộ trình chi tiết đang được cập nhật. Liên hệ admin để biết thêm.

      section.tour-section
        h3.tour-section__title Đội ngũ hướng dẫn
        if tour.guides && tour.guides.length
          .tour-guides
            each guide in tour.guides
              .tour-guide
                img(src=`/img/users/${guide.photo}`, alt=`${guide.name}`)
                div
                  span.tour-guide__role= guide.role === 'lead-guide' ? 'Hướng dẫn viên chính' : 'Hướng dẫn viên'
                  h4.tour-guide__name= guide.name
        else
          p.tour-section__text Danh sách hướng dẫn viên đang được cập nhật.

  section.tour-gallery
    .tour-gallery__header
      span.tour-section__eyebrow Bộ sưu tập
      h2.heading-secondary Hình ảnh từ chuyến đi
    if galleryImages.length
      .tour-gallery__grid
        each image, idx in galleryImages
          figure.tour-gallery__item
            img(src=`/img/tours/${image}`, alt=`${tour.name} - ảnh ${idx + 1}`)
    else
      p.tour-section__text Thư viện hình ảnh đang được cập nhật.

  section.tour-reviews
    .tour-reviews__inner
      .tour-reviews__summary
        span.tour-reviews__eyebrow Khách hàng nói gì?
        h3.tour-reviews__score
          span.tour-reviews__score-value= ratingAverageDisplay
          span.tour-reviews__score-scale /5
        .tour-reviews__summary-stars
          each star in [1,2,3,4,5]
            i(class=star <= ratingAverageStars ? 'fas fa-star' : 'far fa-star')
        p.tour-reviews__summary-text= tour.ratingsQuantity ? `${tour.ratingsQuantity} lượt đánh giá xác thực từ khách đã tham gia.` : 'Chưa có đánh giá nào cho tour này.'
      .tour-reviews__grid
        if initialReviews.length
          each review in initialReviews
            article.tour-review
              header.tour-review__header
                .tour-review__avatar
                  img(src=`/img/users/${review.user.photo || 'default.jpg'}`, alt=review.user.name)
                .tour-review__info
                  strong.tour-review__name= review.user.name
                  span.tour-review__date= new Date(review.createdAt || Date.now()).toLocaleDateString('vi-VN')
              p.tour-review__text= review.review
              .tour-review__rating
                span.tour-review__score= `${review.rating}/5`
                .tour-review__stars
                  each star in [1,2,3,4,5]
                    i(class=star <= review.rating ? 'fas fa-star' : 'far fa-star')
          each review in extraReviews
            article.tour-review.tour-review--extra.is-hidden
              header.tour-review__header
                .tour-review__avatar
                  img(src=`/img/users/${review.user.photo || 'default.jpg'}`, alt=review.user.name)
                .tour-review__info
                  strong.tour-review__name= review.user.name
                  span.tour-review__date= new Date(review.createdAt || Date.now()).toLocaleDateString('vi-VN')
              p.tour-review__text= review.review
              .tour-review__rating
                span.tour-review__score= `${review.rating}/5`
                .tour-review__stars
                  each star in [1,2,3,4,5]
                    i(class=star <= review.rating ? 'fas fa-star' : 'far fa-star')
        else
          p.tour-section__text Chưa có đánh giá nào cho tour này.
      if extraReviews.length
        button.tour-reviews__more(type='button' data-action='reviews-more') Xem thêm đánh giá

block append scripts
  script.
    (() => {
      const moreBtn = document.querySelector('[data-action="reviews-more"]');
      if (moreBtn) {
        moreBtn.addEventListener('click', () => {
          document.querySelectorAll('.tour-review--extra').forEach(card => {
            card.classList.remove('is-hidden');
          });
          moreBtn.remove();
        });
      }
    })();
    document.addEventListener('DOMContentLoaded', () => {
      const quickBookingBtn = document.querySelector('.quick-booking__btn[data-booking-href]');
      const dateSelect = document.getElementById('quickBookingDate');

      if (!quickBookingBtn || !dateSelect) return;

      const baseHref = quickBookingBtn.dataset.bookingHref || '';
      if (!baseHref.includes('/book-tour/')) return;

      quickBookingBtn.addEventListener('click', event => {
        const selectedDate = dateSelect.value;
        if (!selectedDate) return;

        event.preventDefault();
        try {
          const url = new URL(baseHref, window.location.origin);
          url.searchParams.set('startDate', selectedDate);
          window.location.href = url.pathname + url.search;
        } catch {
          window.location.href = `${baseHref}?startDate=${encodeURIComponent(selectedDate)}`;
        }
      });
    });
