extends base
include _authShowcase

block content
  main.main.auth-page
    section.auth-layout
      .auth-panel
        .auth-panel__inner
          .auth-brand
            a.auth-brand__logo(href='/')
              img(src='/img/logo-blue.png' alt='LLK Travel logo')
            .auth-brand__text
              span LLK Travel
              small LƯU GIỮU - LẮNG ĐỌNG - KHÁM PHÁ
          h1.auth-panel__title Chào mừng trở lại
          p.auth-panel__subtitle Truy cập bằng tài khoản LLK để tiếp tục quản lý tours và hỗ trợ khách hàng trong thời gian thực.
          form.form.form--login
            .auth-field
              label.auth-field__label(for='email') Email công việc
              .auth-field__input
                i.fa-regular.fa-envelope
                input#email(type='email', placeholder='ban@llk.travel', required)
            .auth-field
              label.auth-field__label(for='password') Mật khẩu
              .auth-field__input
                i.fa-solid.fa-lock
                input#password(type='password', placeholder='********', required, minlength='8')
              .auth-field__aside
                a.auth-link(href='/forgot-password') Quên mật khẩu?
            button.btn.auth-btn(type='submit') Đăng nhập
          .auth-meta
            span Chưa có tài khoản?
            a.auth-link(href='/signup') Tạo tài khoản mới
      +authShowcase()
