extends adminLayout

block append styles
  link(rel='stylesheet', href='/css/adminChat.css')

block adminContent
  .llk-admin-topbar
    .llk-admin-topbar__left
      h1.llk-admin-topbar__title Trung tâm chăm sóc khách hàng

  section.llk-admin-panel
    .admin-chat-layout
      aside.admin-chat-sidebar
        .admin-chat-sidebar__header
          .admin-chat-sidebar__title
            h3 Phòng chat gần đây
        .admin-chat-search
          input#user-search(type='text', placeholder='Tìm kiếm người dùng...')
        ul#user-list.admin-chat-room-list

      section.admin-chat-conversation
        .admin-chat-conversation__header
          .admin-chat-partner
            img#active-user-avatar.admin-chat-partner__avatar(src='/img/users/default.jpg', alt='Khách hàng đang chọn')
            .admin-chat-partner__meta
              span.admin-chat-partner__label Khách hàng đang chọn
              span#active-user-name.admin-chat-partner__name Chưa chọn phòng chat
              span#active-user-status.admin-chat-partner__status Chọn người dùng ở danh sách bên trái để xem lịch sử.
          .admin-chat-conversation__copy
            h2.heading-secondary Chat hỗ trợ LLK

        #chat-box.admin-chat-messages
          .admin-chat-empty Chọn người dùng để bắt đầu chat

        .admin-chat-conversation__footer
          form#chat-form.admin-chat-form
            input#chat-input.admin-chat-input(type='text', placeholder='Nhập tin nhắn...' autocomplete='off')
            button.admin-chat-send(type='submit')
              i(class='fa-solid fa-paper-plane')
              |  Gửi

      aside.admin-chat-stats
        .admin-chat-stats__header
          h3 Tổng quan
          span#chat-stat-timestamp Cập nhật --
        .admin-chat-stats__cards
          article.admin-chat-card
            span.admin-chat-card__label Room đang hoạt động
            strong#chat-stat-active 0
            small.admin-chat-card__note Bao gồm các phòng vừa được tải
          article.admin-chat-card.admin-chat-card--accent
            span.admin-chat-card__label Tin nhắn mới
            strong#chat-stat-new 0
            small.admin-chat-card__note Tổng tin chưa đọc
          article.admin-chat-card.admin-chat-card--warning
            span.admin-chat-card__label Chưa phản hồi
            strong#chat-stat-pending 0
            small.admin-chat-card__note Phòng đang chờ phản hồi
block append scripts
  script(src='/js/chatAdmin.js')
