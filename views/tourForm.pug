extends adminLayout

block adminContent
  .llk-admin-topbar
    .llk-admin-topbar__left
      h1.llk-admin-topbar__title= title
      p.llk-admin-topbar__subtitle Tạo hoặc chỉnh sửa hành trình và ngày khởi hành.
    .llk-admin-topbar__right
      a.btn.btn--ghost(href='/admin/tours') ← Quay lại danh sách

  section.llk-admin-panel
    form.form.form-tour(enctype='multipart/form-data')
      input#tour-id(type='hidden', value=`${tour ? tour.id : ''}`)

      .tour-form__layout
        .tour-form__main
          .tour-form__stepper
            button(type='button', class='tour-form__stepper-button is-active', data-step='1') 1. Thông tin cơ bản
            button(type='button', class='tour-form__stepper-button', data-step='2') 2. Giá & mô tả
            button(type='button', class='tour-form__stepper-button', data-step='3') 3. Địa điểm & media
            button(type='button', class='tour-form__stepper-button', data-step='4') 4. Hướng dẫn viên

          .tour-form__steps
            .tour-form__step(data-step='1')
              h3.heading-tertiary Thông tin cơ bản
              .form__group
                label.form__label(for='name') Tên tour
                input#name.form__input(type='text', value=`${tour ? tour.name : ''}`, required, minlength='10', maxlength='80')
              .form__group
                label.form__label(for='summary') Tóm tắt
                textarea#summary.form__input(rows='2')= tour ? tour.summary : ''
              .form__group
                label.form__label(for='duration') Thời gian (ngày)
                input#duration.form__input(type='number', value=`${tour ? tour.duration : ''}`, required, min='1')
              .form__group
                label.form__label(for='maxGroupSize') Sức chứa tối đa
                input#maxGroupSize.form__input(type='number', value=`${tour ? tour.maxGroupSize : ''}`, required, min='1')
              .tour-form__actions
                button.btn.btn--small.btn--blue(type='button', data-step-action='next', data-step-target='2') Tiếp theo

            .tour-form__step(data-step='2')
              h3.heading-tertiary Giá & mô tả
              .form__group
                label.form__label(for='price') Giá (VND)
                input#price.form__input(type='number', value=`${tour ? tour.price : ''}`, required, min='0')
              .form__group
                label.form__label(for='priceDiscount') Giảm giá (VND)
                input#priceDiscount.form__input(type='number', value=`${tour ? tour.priceDiscount : ''}`, min='0')
              .form__group
                label.form__label(for='description') Mô tả chi tiết
                textarea#description.form__input(rows='4')= tour ? tour.description : ''
              .tour-form__actions
                button.btn.btn--small.btn--gray(type='button', data-step-action='prev', data-step-target='1') Trước
                button.btn.btn--small.btn--blue(type='button', data-step-action='next', data-step-target='3') Tiếp theo

            .tour-form__step(data-step='3')
              h3.heading-tertiary Địa điểm & hình ảnh
              .form__group
                label.form__label(for='startLocation') Điểm bắt đầu
                input#startLocation.form__input(type='text', value=`${tour && tour.startLocation ? tour.startLocation.description : ''}`, required)
              .form__group
                label.form__label(for='startLocationAddress') Địa chỉ điểm bắt đầu
                input#startLocationAddress.form__input(type='text', value=`${tour && tour.startLocation ? tour.startLocation.address : ''}`, required)
              .form__group
                label.form__label(for='startLocationCoordinates') Tọa độ (lng, lat)
                input#startLocationCoordinates.form__input(type='text', value=`${tour && tour.startLocation ? tour.startLocation.coordinates.join(', ') : ''}`, placeholder='106.695249, 10.775400')
              .form__group
                label.form__label(for='imageCover') Ảnh bìa
                if tour && tour.imageCover
                  .form__current-image
                    img(src=`/img/tours/${tour.imageCover}`, alt='Ảnh bìa hiện tại')
                    p Ảnh bìa hiện tại
                input#imageCover.form__upload(type='file', accept='image/*')
                label(for='imageCover') Chọn ảnh bìa
              .form__group
                label.form__label(for='images') Ảnh tour (tối đa 3 ảnh)
                if tour && tour.images && tour.images.length > 0
                  .form__current-images
                    each img, i in tour.images
                      .form__current-image
                        img(src=`/img/tours/${img}`, alt=`Ảnh tour ${i + 1}`)
                        p Ảnh tour #{i + 1}
                input#images.form__upload(type='file', accept='image/*', multiple)
                label(for='images') Chọn ảnh tour
              .tour-form__actions
                button.btn.btn--small.btn--gray(type='button', data-step-action='prev', data-step-target='2') Trước
                button.btn.btn--small.btn--blue(type='button', data-step-action='next', data-step-target='4') Tiếp theo

            .tour-form__step(data-step='4')
              h3.heading-tertiary Hướng dẫn viên
              .locations-container
                if tour && tour.locations && tour.locations.length > 0
                  each location, i in tour.locations
                    .location-item(data-index=i)
                      button.location-item__remove(type='button') ×
                      .form__group
                        label.form__label Tên địa điểm
                        input.location-description.form__input(type='text', value=location.description, required)
                      .form__group
                        label.form__label Địa chỉ
                        input.location-address.form__input(type='text', value=location.address)
                      .form__group
                        label.form__label Tọa độ (lng, lat)
                        input.location-coordinates.form__input(type='text', value=location.coordinates.join(', '), placeholder='106.695249, 10.775400')
                      .form__group
                        label.form__label Ngày thứ
                        input.location-day.form__input(type='number', value=location.day, required, min='1')
                else
                  .location-item(data-index='0')
                    button.location-item__remove(type='button') ×
                    .form__group
                      label.form__label Tên địa điểm
                      input.location-description.form__input(type='text', placeholder='Tên điểm', required)
                    .form__group
                      label.form__label Địa chỉ
                      input.location-address.form__input(type='text', placeholder='Địa chỉ')
                    .form__group
                      label.form__label Tọa độ (lng, lat)
                      input.location-coordinates.form__input(type='text', placeholder='106.695249, 10.775400')
                    .form__group
                      label.form__label Ngày thứ
                      input.location-day.form__input(type='number', placeholder='1', required, min='1')
              button.btn.btn--small.btn--blue.btn-add-location(type='button') Thêm điểm mới

              h3.heading-tertiary.mt-lg Hướng dẫn viên
              .guides-container
                if tour && tour.guides && tour.guides.length > 0
                  each guide, i in tour.guides
                    .guide-item(data-index=i, data-guide-id=guide.id)
                      button.guide-item__remove(type='button') ×
                      .form__group
                        label.form__label Hướng dẫn viên
                        select.guide-select.form__input(required)
                          option(value='') Chọn hướng dẫn viên
                          each guideOption in guides
                            option(value=guideOption.id, selected=guide.id === guideOption.id)= `${guideOption.name} (${guideOption.role})`
                else
                  .guide-item(data-index='0')
                    button.guide-item__remove(type='button') ×
                    .form__group
                      label.form__label Hướng dẫn viên
                      select.guide-select.form__input(required)
                        option(value='') Chọn hướng dẫn viên
                        each guideOption in guides
                          option(value=guideOption.id)= `${guideOption.name} (${guideOption.role})`
              button.btn.btn--small.btn--blue.btn-add-guide(type='button') Thêm hướng dẫn viên
              .tour-form__actions
                button.btn.btn--small.btn--gray(type='button', data-step-action='prev', data-step-target='3') Trước

        .tour-form__side
          .start-date-panel
            .start-date-panel__header
              h3.heading-tertiary Ngày khởi hành
              p Chỉ quản lý những ngày chưa bắt đầu (chưa mở bán tiếp).
            .start-date-panel__quick
              label.form__label(for='quick-start-date') Thêm nhanh
              input#quick-start-date.form__input(type='date')
              label.form__label(for='quick-start-slots') Slot khả dụng
              input#quick-start-slots.form__input(type='number', min='1', placeholder='Tối đa')
              button.btn.btn--small.btn--blue.btn-add-start-date(type='button') Ghi vào lịch
            .start-dates-container
              if tour && tour.startDates && tour.startDates.length > 0
                each dateObj, i in tour.startDates
                  .start-date-item(data-index=i)
                    button.start-date-item__remove(type='button') ×
                    .form__group
                      label.form__label Ngày khởi hành
                      - const formattedDate = new Date(dateObj.date).toISOString().split('T')[0]
                      input.start-date.form__input(type='date', value=formattedDate, required)
                    .form__group
                      label.form__label Slot tối đa
                      input.start-date-slots.form__input(type='number', min='1', value=dateObj.availableSlots || tour.maxGroupSize)
              else
                .start-date-item(data-index='0')
                  button.start-date-item__remove(type='button') ×
                  .form__group
                    label.form__label Ngày khởi hành
                    input.start-date.form__input(type='date', required)
                  .form__group
                    label.form__label Slot tối đa
                    input.start-date-slots.form__input(type='number', min='1', value=tour ? tour.maxGroupSize : '')

      .form__group.right
        button.btn.btn--small.btn--green.btn-save-tour Lưu
