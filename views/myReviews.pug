extends base
include _userPortalMenu

block content
  main.main.user-portal-instance
    section.user-portal
      +userPortalMenu('reviews')
      .user-portal__content
        .user-portal__content-heading
          h2.heading-secondary Đánh giá của tôi
          p Chia sẻ cảm nhận từng chuyến đi để giúp cộng đồng LLK tin tưởng hơn.

        .reviews-panel
          .reviews-filter
            input.reviews-search(type='text', placeholder='Tìm đánh giá...')
            select.reviews-rating
              option(value='') Tất cả số sao
              option(value='5') 5 sao
              option(value='4') 4 sao
              option(value='3') 3 sao
              option(value='2') 2 sao
              option(value='1') 1 sao

          .reviews-list
            if reviews.length === 0
              .reviews-empty.empty-tours
                h2.heading-secondary Bạn chưa có đánh giá nào
                p.empty-tours-text Khám phá tour và để lại cảm nhận.
                a.my-tour-link(href='/all') Khám phá tour
            else
              each review in reviews
                .review-item
                  .review-item__header
                    a.review-item__tour(href=`/tour/${review.tour.slug}`)
                      img.review-item__img(src=`/img/tours/${review.tour.imageCover}`, alt=`${review.tour.name}`)
                      span= review.tour.name
                    .review-item__rating
                      - for (let i = 1; i <= 5; i++)
                        if i <= review.rating
                          span.review-item__star.review-item__star--active ★
                        else
                          span.review-item__star ★
                  .review-item__content
                    p= review.review
                  .review-item__footer
                    .review-item__date= new Date(review.createdAt).toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' })
                    .review-item__actions
                      button.btn.btn--small.btn--blue.btn-edit-my-review(
                        data-review-id=`${review.id}`,
                        data-tour-id=`${review.tour.id}`,
                        data-review-text=`${review.review}`,
                        data-review-rating=`${review.rating}`
                      ) Chỉnh sửa
                      button.btn.btn--small.btn--red.btn-delete-my-review(data-review-id=`${review.id}`) Xoá

        .modal.hidden#review-modal
          .modal__content
            span.modal__close &times;
            h2.modal__title Sửa đánh giá
            form.form.form-edit-review
              input#review-id(type='hidden')
              input#review-tour-id(type='hidden')
              .form__group
                label.form__label(for='review-text') Nội dung đánh giá
                textarea#review-text.form__input(rows='5', required)
              .form__group
                label.form__label(for='review-rating') Xếp hạng
                .rating-input
                  - for (let i = 5; i >= 1; i--)
                    input(type='radio', id=`star${i}`, name='rating', value=i)
                    label(for=`star${i}`) ★
              .form__group.form__group--actions
                button.btn.btn--small.btn--green.btn-save-review Cập nhật đánh giá
