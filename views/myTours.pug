extends base
include _userPortalMenu

block content
  main.main.user-portal-instance
    section.user-portal
      +userPortalMenu('tours')
      .user-portal__content
        .user-portal__content-heading
          h2.heading-secondary Tour của tôi
          p Tập hợp các chuyến đi, hóa đơn và đánh giá để bạn nắm rõ hành trình của mình.

        .my-tour-collection
          if !tours || tours.length === 0
            .empty-tours
              h2.heading-secondary Bạn chưa có tour nào
              p.empty-tours-text Hãy chọn tour đầu tiên và lên lịch cho mình!
              a.my-tour-link(href='/') Khám phá tour
          else
            - const bookingRecords = Array.isArray(bookings) ? bookings : []
            - const reviewsList = Array.isArray(reviews) ? reviews : []
            each tour in tours
              - const matchedBookings = bookingRecords.filter(b => b.tour.id === tour.id)
              if matchedBookings.length === 0
                .empty-tours
                  p Chưa có đặt chỗ cho tour #{tour.name}.
              else
                each booking in matchedBookings
                  - const startDate = booking.startDate ? new Date(booking.startDate) : null
                  - const fallbackDate = tour.startDates && tour.startDates.length ? new Date(tour.startDates[0]) : null
                  - const displayDate = startDate ? startDate : fallbackDate
                  - const bookingDateLabel = displayDate ? displayDate.toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' }) : 'Chưa xác định'
                  - const today = new Date()
                  - const tourEndDate = startDate ? new Date(startDate) : null
                  - if (tourEndDate) tourEndDate.setDate(tourEndDate.getDate() + tour.duration)
                  - const canReview = tourEndDate ? today > tourEndDate : false
                  - const hasReviewed = reviewsList.some(r => r.tour.id === tour.id && r.user.id === user.id)
                  - const userReview = reviewsList.find(r => r.tour.id === tour.id && r.user.id === user.id)

                  article.my-tour-entry
                    .my-tour-entry__hero
                      .my-tour-entry__hero-media(style=`background-image: url('/img/tours/${tour.imageCover}')`)
                      .my-tour-entry__hero-overlay
                        span.my-tour-entry__duration= `${tour.duration} ngày`
                        span.my-tour-entry__date= bookingDateLabel
                        span.my-tour-entry__code= `Mã tour: #${booking.id.slice(-8).toUpperCase()}`

                    .my-tour-entry__body
                      h3.my-tour-entry__title= tour.name
                      p.my-tour-entry__location
                        svg
                          use(xlink:href='/img/icons.svg#icon-map-pin')
                        span= tour.startLocation.description
                      p.my-tour-entry__summary= tour.summary

                      .my-tour-entry__meta
                        span
                          svg
                            use(xlink:href='/img/icons.svg#icon-flag')
                          | #{tour.locations.length} địa điểm
                        span
                          svg
                            use(xlink:href='/img/icons.svg#icon-user')
                          | #{booking.participants || 1} khách

                      .my-tour-entry__prices
                        .my-tour-entry__price
                          strong= `${booking.price.toLocaleString('vi-VN')} VNĐ`
                          small Giá thanh toán
                        .my-tour-entry__rating
                          strong= tour.ratingsAverage.toFixed(1)
                          small Đánh giá (#{tour.ratingsQuantity})

                      .my-tour-entry__actions
                        a.my-tour-entry__btn(href=`/tour/${tour.slug}`)
                          svg
                            use(xlink:href='/img/icons.svg#icon-eye')
                          span Xem chi tiết
                        if booking
                          a.my-tour-entry__btn.my-tour-entry__btn--outline(href=`/booking-invoice/${booking.id}`)
                            svg
                              use(xlink:href='/img/icons.svg#icon-credit-card')
                            span Hoá đơn
                        if canReview
                          if !hasReviewed
                            button.my-tour-entry__btn.my-tour-entry__btn--accent(type='button', data-tour-id=tour.id)
                              svg
                                use(xlink:href='/img/icons.svg#icon-star')
                              span Đánh giá
                          else if userReview
                            button.my-tour-entry__btn.my-tour-entry__btn--accent(type='button',
                              data-review-id=userReview.id,
                              data-tour-id=tour.id,
                              data-review-text=userReview.review,
                              data-review-rating=userReview.rating
                            )
                              svg
                                use(xlink:href='/img/icons.svg#icon-edit-2')
                              span Sửa đánh giá

        .modal.hidden#review-modal
          .modal__content
            span.modal__close &times;
            h2.modal__title Đánh giá tour
            form.form.form-add-review
              input#review-tour-id(type='hidden')
              input#review-id(type='hidden')
              input#is-edit(type='hidden', value='false')
              .form__group
                label.form__label(for='review-text') Nội dung đánh giá
                textarea#review-text.form__input(rows='5', required)
              .form__group
                label.form__label(for='review-rating') Xếp hạng
                .rating-input
                  - for (let i = 5; i >= 1; i--)
                    input(type='radio', id=`star${i}`, name='rating', value=i)
                    label(for=`star${i}`) ★
              .form__group.form__group--actions
                button.btn.btn--small.btn--green.btn-save-review Gửi đánh giá
