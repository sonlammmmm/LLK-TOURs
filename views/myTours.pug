extends base
include _userPortalMenu

block content
  main.main.user-portal-instance
    section.user-portal
      +userPortalMenu('tours')
      .user-portal__content
        .user-portal__content-heading
          h2.heading-secondary Hành trình của bạn
          p Theo dõi nhanh các chuyến đi, trạng thái và đánh giá ở một nơi duy nhất.
        if !sortedBookings || sortedBookings.length === 0
          .empty-tours
            h2.heading-secondary Bạn chưa có tour nào
            p.empty-tours-text Hãy khám phá hành trình mới và lưu lại chuyến đi đầu tiên của bạn.
            a.my-tour-link(href='/all') Khám phá tour
        else
          .my-tour-dashboard
            .my-tour-dashboard__intro
              .intro-text
                h3.heading-tertiary Bảng điều khiển hành trình
                p Cập nhật nhanh các chuyến đi, trạng thái và hóa đơn.
              .intro-actions
                a.btn.btn--green(href='/all') Khám phá tour mới
                a.btn.btn--outline(href='/my-billing') Lịch sử thanh toán
            .my-tour-dashboard__stats
              each stat in summaryStats
                .stat-card
                  strong.stat-card__value= stat.value
                  span.stat-card__label= stat.label
                  small.stat-card__detail= stat.detail
            if pendingReviewCount
              .my-tour-dashboard__alert
                svg
                  use(xlink:href='/img/icons.svg#icon-star')
                span Bạn còn #{pendingReviewCount} đánh giá chưa gửi
          .my-tour-grid
            each entry in sortedBookings
              article.my-tour-card
                .my-tour-card__hero
                  .my-tour-card__hero-media(style=`background-image: url('/img/tours/${entry.tour.imageCover}')`)
                    .my-tour-card__hero-overlay
                      span.my-tour-card__hero-badge= entry.statusText
                      span.my-tour-card__hero-date= entry.dateLabel
                      span.my-tour-card__hero-code= `Mã tour: #${entry.bookingCode}`
                .my-tour-card__body
                  h3.my-tour-card__title= entry.tour.name
                  p.my-tour-card__location
                    svg
                      use(xlink:href='/img/icons.svg#icon-map-pin')
                    span= entry.tour.startLocation.description
                  p.my-tour-card__summary= entry.tour.summary
                  .my-tour-card__info
                    span
                      svg
                        use(xlink:href='/img/icons.svg#icon-flag')
                      | #{entry.tour.locations ? entry.tour.locations.length : 0} điểm đến
                    span
                      svg
                        use(xlink:href='/img/icons.svg#icon-user')
                      | #{entry.booking.participants || 1} khách
                    span
                      svg
                        use(xlink:href='/img/icons.svg#icon-calendar')
                      | #{entry.tour.duration} ngày
                  .my-tour-card__footer
                    .my-tour-card__price
                      strong= `${entry.paidAmountLabel} VNĐ`
                      small Giá thanh toán
                    .my-tour-card__actions
                      a.my-tour-card__btn(href=`/tour/${entry.tour.slug}`)
                        svg
                          use(xlink:href='/img/icons.svg#icon-eye')
                        span Xem chi tiết
                      if entry.booking
                        a.my-tour-card__btn.my-tour-card__btn--outline(href=`/booking-invoice/${entry.booking.id}`)
                          svg
                            use(xlink:href='/img/icons.svg#icon-credit-card')
                          span Hóa đơn
                      if entry.canReview
                        if !entry.hasReviewed
                          button.my-tour-card__btn.my-tour-card__btn--accent.btn-add-review(type='button', data-tour-id=entry.tour.id)
                            svg
                              use(xlink:href='/img/icons.svg#icon-star')
                            span Đánh giá
                        else if entry.userReview
                          button.my-tour-card__btn.my-tour-card__btn--accent.btn-edit-my-review(type='button',
                            data-review-id=entry.userReview.id,
                            data-tour-id=entry.tour.id,
                            data-review-text=entry.userReview.review,
                            data-review-rating=entry.userReview.rating
                          )
                            svg
                              use(xlink:href='/img/icons.svg#icon-edit-2')
                            span Sửa đánh giá
        .modal.hidden#review-modal
          .modal__content
            span.modal__close &times;
            h2.modal__title Gửi đánh giá tour
            form.form.form-add-review
              input#review-tour-id(type='hidden')
              input#review-id(type='hidden')
              input#is-edit(type='hidden', value='false')
              .form__group
                label.form__label(for='review-text') Nội dung đánh giá
                textarea#review-text.form__input(rows='5', required)
              .form__group
                label.form__label(for='review-rating') Xếp hạng
                .rating-input
                  - for (let i = 5; i >= 1; i--)
                    input(type='radio', id=`star${i}`, name='rating', value=i)
                    label(for=`star${i}`) ★
              .form__group.form__group--actions
                button.btn.btn--small.btn--green.btn-save-review Đánh giá
