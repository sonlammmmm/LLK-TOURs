extends base

block append head
  link(rel='stylesheet' href='/css/landing.css')

block content
  - hideFooter = true
  - hideChatFloat = true
  - const fallbackImage = '/img/banner1.png';
  
  //- Logic xử lý dữ liệu Tour (giữ nguyên)
  -
    const toursArray = Array.isArray(tours) ? tours : [];
    const searchPayload =
      searchParams && typeof searchParams === 'object' ? searchParams : {};
    const activeLandingSearch =
      searchPayload.search ||
      searchPayload.name ||
      '';
    const sliderStartDateValue = searchPayload.startDates || '';
    const formatLandingDateLabel = iso => {
      if (!iso) return '';
      const parsed = new Date(iso);
      if (Number.isNaN(parsed.getTime())) return '';
      return parsed.toLocaleDateString('vi-VN', {
        weekday: 'short',
        day: '2-digit',
        month: 'long',
        year: 'numeric'
      });
    };
    const sliderStartDateLabel = formatLandingDateLabel(sliderStartDateValue);
    const getSlots = (tour) => {
      const values = [tour.available_slots, tour.availableSlots, tour.remainingSlots, tour.maxGroupSize];
      for (const value of values) {
        if (typeof value === 'number' && !Number.isNaN(value) && value > 0) return value;
      }
      return 0;
    };
    const getSales = (t) => t.sales_count ?? t.salesCount ?? t.ratingsQuantity ?? 0;
    // Lọc tour còn chỗ và lấy top 5 bán chạy
    const sliderTours = toursArray
      .filter(t => getSlots(t) > 0)
      .sort((a, b) => getSales(b) - getSales(a))
      .slice(0, 5);

  if sliderTours.length > 0
    section#cinematic-slider.slider-container(data-autoplay='6000')
      
      //- 1. BACKGROUNDS LAYER
      .slider-backgrounds
        each tour, idx in sliderTours
          - const bgImage = tour.imageCover ? `/img/tours/${tour.imageCover}` : fallbackImage;
          .slide-bg(class=idx === 0 ? 'is-active' : '' data-index=idx style=`background-image:url('${bgImage}')`)

      //- 2. UI & TEXT LAYER
      .slider-ui
        //- Search Box
        .slider-search-shell
          form.slider-search(action='/all' method='GET' autocomplete='off')
            .slider-search__row
              input.slider-search__input(
                type='search'
                name='search'
                placeholder='Bạn muốn đến nơi nào...?'
                value=activeLandingSearch
              )
              button(type='submit' aria-label='Tìm tour')
                i.fa-solid.fa-magnifying-glass
            input#sliderStartDateInput(type='hidden' name='startDates' value=sliderStartDateValue)
          .slider-date-filter(
            data-date-picker
            data-selected-date=sliderStartDateValue
            class={ 'has-value': Boolean(sliderStartDateValue) }
          )
            .slider-date-filter__controls
              button.slider-date-filter__trigger(type='button' data-toggle-date aria-label='Chọn ngày khởi hành' aria-expanded='false')
                span.slider-date-filter__value(data-placeholder='Chọn ngày khởi hành')= sliderStartDateLabel || 'Chọn ngày khởi hành'
                span.slider-date-filter__icon
                  i.fa-regular.fa-calendar
              button.slider-date-filter__clear(
                type='button'
                data-clear-date
                aria-label='Xóa ngày đã chọn'
                class={ 'is-visible': Boolean(sliderStartDateValue) }
              )
                i.fa-regular.fa-circle-xmark
            .slider-date-picker(role='dialog' aria-modal='false')
              .date-picker__header
                button.date-picker__nav-btn(type='button' data-shift-month='-1' aria-label='Tháng trước')
                  i.fa-solid.fa-chevron-left
                .date-picker__current-month(data-month-label) Tháng hiện tại
                button.date-picker__nav-btn(type='button' data-shift-month='1' aria-label='Tháng tiếp theo')
                  i.fa-solid.fa-chevron-right
              .date-picker__weekdays
                each day in ['T2','T3','T4','T5','T6','T7','CN']
                  span= day
              .date-picker__grid(data-calendar-grid)
        .slider-content-wrapper
          each tour, idx in sliderTours
            - const maxSlots = tour.maxGroupSize || getSlots(tour) || '—';
            - const durationLabel = tour.duration ? `${tour.duration} ngày` : 'Đang cập nhật';
            - const ratingLabel = typeof tour.ratingsAverage === 'number' ? `${tour.ratingsAverage.toFixed(1)}/5` : 'Chưa có đánh giá';
            - const priceLabel = typeof tour.price === 'number' ? `Chỉ từ ${tour.price.toLocaleString('vi-VN')} VNĐ` : 'Liên hệ để nhận giá';
            .slide-text-item(class=idx === 0 ? 'is-active' : '' data-index=idx)
              span.text-location= tour.startLocation && tour.startLocation.description ? tour.startLocation.description : 'Khám phá ngay'
              h1.text-heading= tour.name
              .text-meta
                span.meta-pill #{maxSlots} chỗ tối đa
                span.meta-pill= durationLabel
                span.meta-pill Đánh giá #{ratingLabel}
                span.meta-pill= priceLabel
              .slider-actions
                a.btn-explore(href=`/tour/${tour.slug}`)
                  | Xem chi tiết
                  svg(width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                    line(x1="5" y1="12" x2="19" y2="12")
                    polyline(points="12 5 19 12 12 19")
                a.btn-outline(href='/all') Khám phá thêm

      //- 3. NAVIGATION LAYER
      .slider-nav-wrapper
        .slider-nav-viewport
          .slider-nav
            each tour, idx in sliderTours
              - const thumbImage = tour.imageCover ? `/img/tours/${tour.imageCover}` : fallbackImage;
              .nav-card(data-index=idx)
                img(src=thumbImage alt=tour.name loading='lazy' decoding='async')
                .nav-card-info
                  h4= tour.name
                  span 0#{idx + 1}
  else
    section.slider-empty(style="height:100vh; display:grid; place-items:center; background:#0a0a0a; color:#fff;")
      h2 Đang cập nhật hành trình mới...

block append scripts
  //- Load GSAP
  script(src='https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js')
  
  script.
    document.addEventListener('DOMContentLoaded', function () {
      const slider = document.querySelector('#cinematic-slider');
      if (!slider) return;
      const sliderSearchInput = slider.querySelector('.slider-search__input');
      const sliderDateFilter = slider.querySelector('[data-date-picker]');
      const sliderDateInput = slider.querySelector('#sliderStartDateInput');
      if (sliderDateFilter && sliderDateInput) {
        initSliderDateFilter(sliderDateFilter, sliderDateInput);
      }

      const backgrounds = slider.querySelectorAll('.slide-bg');
      const textItems = slider.querySelectorAll('.slide-text-item');
      const navViewport = slider.querySelector('.slider-nav-viewport');
      const navTrack = navViewport ? navViewport.querySelector('.slider-nav') : null;
      let navCards = navTrack ? Array.from(navTrack.children) : [];
      const navBaseCount = navCards.length;
      const hasGSAP = typeof window.gsap !== 'undefined';
      let virtualNavIndex = navBaseCount;
      let activeNavCard = null;
      let navScrollTween = null;
      let navScrollCompletionTimeout = null;
      const NAV_SCROLL_DURATION = 0.85;
      const NAV_NATIVE_SCROLL_MS = 550;
      
      let currentIndex = 0;
      let isAnimating = false;
      const totalSlides = backgrounds.length;
      const autoplayTime = 6000;

      if (sliderSearchInput && !sliderSearchInput.value) {
        const typingText = 'Bạn muốn đến nơi nào...?';
        const typingDelay = 84;
        const typingStartDelay = 400;
        const typingLoopDelay = 5000;
        let typingIndex = 0;
        let typingTimeout;
        let typingLoopTimeout;
        let isTyping = false;

        sliderSearchInput.placeholder = '';

        const shouldPauseTyping = () =>
          document.activeElement === sliderSearchInput || Boolean(sliderSearchInput.value);

        const clearTypingTimers = () => {
          clearTimeout(typingTimeout);
          clearTimeout(typingLoopTimeout);
        };

        const setFullPlaceholder = () => {
          sliderSearchInput.placeholder = typingText;
        };

        const stopTypingEffect = () => {
          clearTypingTimers();
          setFullPlaceholder();
          isTyping = false;
        };

        const scheduleTypingCycle = (delay = typingLoopDelay) => {
          clearTimeout(typingLoopTimeout);
          if (shouldPauseTyping()) return;
          typingLoopTimeout = setTimeout(() => {
            startTyping();
          }, delay);
        };

        const typeNextCharacter = () => {
          if (shouldPauseTyping()) {
            stopTypingEffect();
            return;
          }
          sliderSearchInput.placeholder = typingText.slice(0, typingIndex + 1);
          typingIndex += 1;
          if (typingIndex < typingText.length) {
            typingTimeout = setTimeout(typeNextCharacter, typingDelay);
          } else {
            setFullPlaceholder();
            isTyping = false;
            scheduleTypingCycle();
          }
        };

        function startTyping() {
          if (isTyping || shouldPauseTyping()) {
            setFullPlaceholder();
            return;
          }
          isTyping = true;
          typingIndex = 0;
          sliderSearchInput.placeholder = '';
          typingTimeout = setTimeout(typeNextCharacter, typingDelay);
        }

        typingTimeout = setTimeout(startTyping, typingStartDelay);

        sliderSearchInput.addEventListener('focus', stopTypingEffect);
        sliderSearchInput.addEventListener('input', stopTypingEffect);
        sliderSearchInput.addEventListener('blur', () => {
          if (!sliderSearchInput.value) {
            scheduleTypingCycle();
          }
        });
      }

      function initSliderDateFilter(filterElement, hiddenInput) {
        const toggleButton = filterElement.querySelector('[data-toggle-date]');
        const clearButton = filterElement.querySelector('[data-clear-date]');
        const monthLabelEl = filterElement.querySelector('[data-month-label]');
        const calendarGrid = filterElement.querySelector('[data-calendar-grid]');
        const navButtons = filterElement.querySelectorAll('[data-shift-month]');
        const valueLabel = filterElement.querySelector('.slider-date-filter__value');
        const placeholderText =
          (valueLabel && valueLabel.dataset.placeholder) ||
          (valueLabel ? valueLabel.textContent : '');
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const monthFormatter = new Intl.DateTimeFormat('vi-VN', {
          month: 'long',
          year: 'numeric'
        });
        const displayFormatter = new Intl.DateTimeFormat('vi-VN', {
          weekday: 'short',
          day: '2-digit',
          month: 'long',
          year: 'numeric'
        });

        const parseLocalDate = value => {
          if (!value || typeof value !== 'string') return null;
          const parts = value.split('-');
          if (parts.length !== 3) return null;
          const [yearStr, monthStr, dayStr] = parts;
          const year = Number(yearStr);
          const month = Number(monthStr);
          const day = Number(dayStr);
          if (!year || !month || !day) return null;
          const parsed = new Date(year, month - 1, day);
          if (Number.isNaN(parsed.getTime())) return null;
          parsed.setHours(0, 0, 0, 0);
          return parsed;
        };

        const formatIsoDate = date => {
          const year = date.getFullYear();
          const month = String(date.getMonth() + 1).padStart(2, '0');
          const day = String(date.getDate()).padStart(2, '0');
          return `${year}-${month}-${day}`;
        };

        let selectedDate = parseLocalDate(hiddenInput.value);
        let viewMonth = selectedDate
          ? new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1)
          : new Date(today.getFullYear(), today.getMonth(), 1);

        function updateValueLabel() {
          if (!valueLabel) return;
          if (selectedDate) {
            valueLabel.textContent = displayFormatter.format(selectedDate);
          } else {
            const fallback =
              (valueLabel.dataset && valueLabel.dataset.placeholder) || placeholderText || '';
            valueLabel.textContent = fallback;
          }
        }

        function syncSelectionState() {
          const hasValue = Boolean(selectedDate);
          filterElement.classList.toggle('has-value', hasValue);
          filterElement.dataset.selectedDate = selectedDate ? formatIsoDate(selectedDate) : '';
          if (clearButton) {
            clearButton.classList.toggle('is-visible', hasValue);
          }
          updateValueLabel();
        }

        function renderCalendar() {
          if (!calendarGrid) return;
          const startOfMonth = new Date(viewMonth.getFullYear(), viewMonth.getMonth(), 1);
          if (monthLabelEl) {
            monthLabelEl.textContent = monthFormatter.format(startOfMonth);
          }
          const fragment = document.createDocumentFragment();
          const leadingEmpty = (startOfMonth.getDay() + 6) % 7;
          for (let i = 0; i < leadingEmpty; i += 1) {
            const spacer = document.createElement('span');
            spacer.className = 'date-picker__day is-empty';
            fragment.appendChild(spacer);
          }
          const daysInMonth = new Date(
            startOfMonth.getFullYear(),
            startOfMonth.getMonth() + 1,
            0
          ).getDate();
          for (let day = 1; day <= daysInMonth; day += 1) {
            const current = new Date(startOfMonth.getFullYear(), startOfMonth.getMonth(), day);
            current.setHours(0, 0, 0, 0);
            const cell = document.createElement('button');
            cell.type = 'button';
            cell.className = 'date-picker__day';
            cell.textContent = String(day).padStart(2, '0');
            const isoValue = formatIsoDate(current);
            cell.dataset.dateValue = isoValue;
            if (current < today) {
              cell.disabled = true;
              cell.classList.add('is-disabled');
            }
            if (selectedDate && current.getTime() === selectedDate.getTime()) {
              cell.classList.add('is-selected');
            }
            fragment.appendChild(cell);
          }
          calendarGrid.innerHTML = '';
          calendarGrid.appendChild(fragment);
        }

        function setCalendarOpen(isOpen) {
          filterElement.classList.toggle('is-open', Boolean(isOpen));
          if (toggleButton) {
            toggleButton.setAttribute('aria-expanded', Boolean(isOpen).toString());
          }
        }

        function handleDateSelection(nextDate) {
          if (nextDate) {
            selectedDate = new Date(
              nextDate.getFullYear(),
              nextDate.getMonth(),
              nextDate.getDate()
            );
            hiddenInput.value = formatIsoDate(selectedDate);
          } else {
            selectedDate = null;
            hiddenInput.value = '';
          }
          syncSelectionState();
          renderCalendar();
        }

        if (toggleButton) {
          toggleButton.addEventListener('click', event => {
            event.preventDefault();
            const nextState = !filterElement.classList.contains('is-open');
            setCalendarOpen(nextState);
            if (nextState) {
              renderCalendar();
            }
          });
        }

        if (calendarGrid) {
          calendarGrid.addEventListener('click', event => {
            const target = event.target.closest('[data-date-value]');
            if (!target || target.disabled) return;
            const chosen = parseLocalDate(target.dataset.dateValue);
            if (!chosen) return;
            handleDateSelection(chosen);
            setCalendarOpen(false);
          });
        }

        if (clearButton) {
          clearButton.addEventListener('click', () => {
            handleDateSelection(null);
            setCalendarOpen(false);
          });
        }

        navButtons.forEach(button => {
          const shift = Number(button.dataset.shiftMonth);
          if (Number.isNaN(shift)) return;
          button.addEventListener('click', event => {
            event.preventDefault();
            viewMonth = new Date(viewMonth.getFullYear(), viewMonth.getMonth() + shift, 1);
            renderCalendar();
          });
        });

        document.addEventListener('click', event => {
          if (!filterElement.classList.contains('is-open')) return;
          if (!filterElement.contains(event.target)) {
            setCalendarOpen(false);
          }
        });

        document.addEventListener('keydown', event => {
          if (event.key === 'Escape') {
            setCalendarOpen(false);
          }
        });

        syncSelectionState();
        renderCalendar();
      }

      function animateTextIn(index) {
        const item = textItems[index];
        const location = item.querySelector('.text-location');
        const heading = item.querySelector('.text-heading');
        const meta = item.querySelector('.text-meta');
        const btn = item.querySelector('.btn-explore');
        const elements = [location, heading, meta, btn].filter(Boolean);
        if (hasGSAP) {
          // Kill any running tweens on these elements
          elements.forEach(el => gsap.killTweensOf(el));
          gsap.set(elements, { y: 25, opacity: 0, force3D: true });
          return gsap.to(elements, {
            y: 0,
            opacity: 1,
            duration: 0.65,
            stagger: 0.08,
            ease: "power2.out",
            delay: 0.15,
            force3D: true
          });
        } else {
          elements.forEach((el) => {
            el.style.opacity = '1';
            el.style.transform = 'translateZ(0)';
          });
          return null;
        }
      }

      function animateTextOut(index) {
        const item = textItems[index];
        const elements = Array.from(item.children).filter(Boolean);
        if (hasGSAP) {
          elements.forEach(el => gsap.killTweensOf(el));
          return gsap.to(elements, {
            y: -20,
            opacity: 0,
            duration: 0.4,
            stagger: 0.03,
            ease: "power2.in",
            force3D: true
          });
        } else {
          item.classList.remove('is-active');
          return null;
        }
      }

      function animateBg(index) {
        const bg = backgrounds[index];
        if (!bg) return null;
        if (hasGSAP) {
          gsap.killTweensOf(bg);
          gsap.set(bg, { scale: 1.1, opacity: 0, force3D: true });
          const tl = gsap.timeline();
          tl.to(bg, { opacity: 1, duration: 0.8, ease: "power2.out" });
          tl.to(bg, { scale: 1, duration: 5.5, ease: "none", force3D: true }, 0);
          return tl;
        } else {
          bg.style.opacity = '1';
          bg.style.transform = 'scale(1) translateZ(0)';
          return null;
        }
      }

      function animateBgOut(index) {
        const bg = backgrounds[index];
        if (!bg) return null;
        if (hasGSAP) {
          gsap.killTweensOf(bg);
          return gsap.to(bg, { opacity: 0, duration: 0.6, ease: "power2.in", force3D: true });
        } else {
          bg.style.opacity = '0';
          return null;
        }
      }

      // Slide transition orchestrator using GSAP timeline
      let activeTimeline = null;
      function goToSlide(index) {
        if (isAnimating || index === currentIndex) return;
        isAnimating = true;

        // Kill any running master timeline
        if (activeTimeline && activeTimeline.kill) {
          activeTimeline.kill();
        }

        const prevIndex = currentIndex;
        currentIndex = index;

        // Navigation
        const wrapTransition =
          (prevIndex === totalSlides - 1 && currentIndex === 0) ||
          (prevIndex === 0 && currentIndex === totalSlides - 1);
        moveNavToLogicalIndex(currentIndex, true, wrapTransition);

        if (hasGSAP) {
          activeTimeline = gsap.timeline({
            onComplete: () => {
              isAnimating = false;
              activeTimeline = null;
            }
          });

          // Phase 1: Fade out old bg and text in parallel
          const textOutTween = animateTextOut(prevIndex);
          const bgOutTween = animateBgOut(prevIndex);

          if (textOutTween) activeTimeline.add(textOutTween, 0);
          if (bgOutTween) activeTimeline.add(bgOutTween, 0);

          // Phase 2: After a brief overlap, bring in new content
          activeTimeline.call(() => {
            backgrounds[prevIndex].classList.remove('is-active');
            textItems[prevIndex].classList.remove('is-active');
            backgrounds[currentIndex].classList.add('is-active');
            textItems[currentIndex].classList.add('is-active');
          }, null, 0.35);

          const bgInTween = animateBg(currentIndex);
          const textInTween = animateTextIn(currentIndex);

          if (bgInTween) activeTimeline.add(bgInTween, 0.35);
          if (textInTween) activeTimeline.add(textInTween, 0.4);
        } else {
          // Fallback without GSAP
          backgrounds[prevIndex].classList.remove('is-active');
          backgrounds[prevIndex].style.opacity = '0';
          textItems[prevIndex].classList.remove('is-active');

          backgrounds[currentIndex].classList.add('is-active');
          backgrounds[currentIndex].style.opacity = '1';
          backgrounds[currentIndex].style.transform = 'scale(1) translateZ(0)';
          textItems[currentIndex].classList.add('is-active');

          setTimeout(() => { isAnimating = false; }, 300);
        }
      }

      function nextSlide() {
        const next = (currentIndex + 1) % totalSlides;
        goToSlide(next);
      }

      function cloneNavCard(card) {
        const clone = card.cloneNode(true);
        clone.classList.remove('is-active');
        return clone;
      }

      function setupNavCarousel() {
        if (!navTrack || !navBaseCount) return;
        const originals = navCards.slice();
        const prependClones = originals.map(cloneNavCard).reverse();
        prependClones.forEach((clone) => navTrack.insertBefore(clone, navTrack.firstChild));
        const appendClones = originals.map(cloneNavCard);
        appendClones.forEach((clone) => navTrack.appendChild(clone));
        navCards = Array.from(navTrack.children);
        navCards.forEach((card) => card.addEventListener('click', handleNavClick));
        virtualNavIndex = navBaseCount;
        requestAnimationFrame(() => {
          const initialCard = navCards[virtualNavIndex];
          if (initialCard) {
            highlightNavCard(initialCard);
            scrollNavCardIntoView(initialCard, { smooth: false });
          }
        });
      }

      function handleNavClick(event) {
        const idx = Number(event.currentTarget.dataset.index);
        if (Number.isNaN(idx)) return;
        resetTimer();
        goToSlide(idx);
      }

      function findClosestNavCard(targetIndex) {
        let bestCard = null;
        let bestDistance = Infinity;
        navCards.forEach((card, idx) => {
          if (Number(card.dataset.index) !== targetIndex) return;
          const distance = Math.abs(idx - virtualNavIndex);
          if (distance < bestDistance) {
            bestDistance = distance;
            bestCard = { card, idx };
          }
        });
        return bestCard;
      }

      function highlightNavCard(card) {
        if (!card) return;
        if (card === activeNavCard) {
          card.classList.add('is-active');
          return;
        }
        const previousCard = activeNavCard;
        activeNavCard = card;
        activeNavCard.classList.add('is-active');
        if (previousCard && previousCard !== activeNavCard) {
          previousCard.classList.remove('is-active');
        }
      }

      function scrollNavCardIntoView(card, options = {}) {
        if (!navViewport || !card) {
          if (options && typeof options.onComplete === 'function') {
            options.onComplete();
          }
          return;
        }
        const { smooth = true, onComplete } = options;
        if (navScrollTween && typeof navScrollTween.kill === 'function') {
          navScrollTween.kill();
          navScrollTween = null;
        }
        if (navScrollCompletionTimeout) {
          clearTimeout(navScrollCompletionTimeout);
          navScrollCompletionTimeout = null;
        }
        const target = card.offsetLeft - (navViewport.clientWidth / 2 - card.offsetWidth / 2);
        if (!smooth) {
          navViewport.scrollTo({ left: target, behavior: 'auto' });
          if (typeof onComplete === 'function') onComplete();
          return;
        }
        if (hasGSAP && typeof gsap.to === 'function') {
          navScrollTween = gsap.to(navViewport, {
            scrollLeft: target,
            duration: NAV_SCROLL_DURATION,
            ease: 'power2.out',
            overwrite: 'auto',
            onComplete: () => {
              navScrollTween = null;
              if (typeof onComplete === 'function') onComplete();
            }
          });
          return;
        }
        navViewport.scrollTo({ left: target, behavior: 'smooth' });
        if (typeof onComplete === 'function') {
          navScrollCompletionTimeout = setTimeout(() => {
            navScrollCompletionTimeout = null;
            onComplete();
          }, NAV_NATIVE_SCROLL_MS);
        }
      }

      function normalizeNavPosition(wrapTransition = false) {
        if (!navViewport || !navBaseCount || !navCards.length) return;
        let normalized = false;
        if (virtualNavIndex >= navBaseCount * 2) {
          virtualNavIndex -= navBaseCount;
          normalized = true;
        } else if (virtualNavIndex < navBaseCount) {
          virtualNavIndex += navBaseCount;
          normalized = true;
        }
        const currentCard = navCards[virtualNavIndex];
        if (!currentCard) return;
        if (normalized) {
          // Disable transitions on ALL nav cards to prevent flicker during instant jump
          const transitionBackup = [];
          navCards.forEach((card, i) => {
            transitionBackup[i] = card.style.transition;
            card.style.transition = 'none';
          });
          // Instantly swap highlight and scroll position
          if (activeNavCard) activeNavCard.classList.remove('is-active');
          activeNavCard = currentCard;
          currentCard.classList.add('is-active');
          scrollNavCardIntoView(currentCard, { smooth: false });
          // Re-enable transitions after browser has painted the instant state
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              navCards.forEach((card, i) => {
                card.style.transition = transitionBackup[i] || '';
              });
            });
          });
          return;
        }
        if (wrapTransition) {
          highlightNavCard(currentCard);
        }
      }

      function moveNavToLogicalIndex(targetIndex, smooth = true, wrapTransition = false) {
        if (!navTrack || !navViewport || !navCards.length) return;
        const candidate = findClosestNavCard(targetIndex);
        if (!candidate) return;
        virtualNavIndex = candidate.idx;
        highlightNavCard(candidate.card);
        scrollNavCardIntoView(candidate.card, {
          smooth,
          onComplete: () => normalizeNavPosition(wrapTransition)
        });
      }

      // Autoplay logic — uses requestAnimationFrame + visibility API for smooth, efficient timing
      let autoplayLastTime = 0;
      let autoplayRafId = null;
      let autoplayPaused = false;

      function autoplayTick(timestamp) {
        if (autoplayPaused || isAnimating) {
          autoplayLastTime = timestamp;
          autoplayRafId = requestAnimationFrame(autoplayTick);
          return;
        }
        if (!autoplayLastTime) autoplayLastTime = timestamp;
        const elapsed = timestamp - autoplayLastTime;
        if (elapsed >= autoplayTime) {
          autoplayLastTime = timestamp;
          nextSlide();
        }
        autoplayRafId = requestAnimationFrame(autoplayTick);
      }

      function startTimer() {
        autoplayLastTime = 0;
        if (autoplayRafId) cancelAnimationFrame(autoplayRafId);
        autoplayRafId = requestAnimationFrame(autoplayTick);
      }
      function resetTimer() {
        autoplayLastTime = 0;
      }

      // Pause autoplay when tab is hidden to save resources
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          autoplayPaused = true;
        } else {
          autoplayPaused = false;
          autoplayLastTime = 0; // reset so it doesn't jump immediately
        }
      });

      // --- INIT ---
      // Chạy animation cho slide đầu tiên ngay khi load
      if (textItems.length) {
        textItems[0].classList.add('is-active');
        animateTextIn(0);
      }
      if (backgrounds.length) {
        backgrounds[0].classList.add('is-active');
        animateBg(0);
      }
      if (navTrack && navBaseCount) {
        setupNavCarousel();
        moveNavToLogicalIndex(0, false);
      }
      if (totalSlides > 1) {
        startTimer();
      }

      // Debounced resize handler to prevent layout thrashing
      let resizeTimeout;
      window.addEventListener('resize', () => {
        if (resizeTimeout) clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
          moveNavToLogicalIndex(currentIndex, false);
        }, 150);
      });
    });
