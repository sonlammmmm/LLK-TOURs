extends adminLayout

block adminContent
  .llk-admin-topbar
    .llk-admin-topbar__left
      h1.llk-admin-topbar__title Dashboard Overview
      p.llk-admin-topbar__subtitle Welcome back! Here's what's happening với hệ thống của bạn hôm nay.
    .llk-admin-topbar__right
      div.llk-admin-topbar__search
        svg(width='16' height='16')
          use(xlink:href='/img/icons.svg#icon-search')
        input(type='text', placeholder='Search…')
      button.btn.btn--ghost(type='button')
        svg(width='16' height='16')
          use(xlink:href='/img/icons.svg#icon-bell')
      a.btn.btn--small.btn--green(href='/admin/tours/new') Tạo tour nhanh

  section.llk-admin-panel.llk-admin-dashboard
    .llk-admin-panel__stats.llk-admin-panel__stats--wide
      .llk-admin-stat-card
        span.llk-admin-stat-card__label Doanh thu hôm nay (#{formattedDate})
        strong.llk-admin-stat-card__value #{todayRevenue.toLocaleString('vi-VN')} ₫
        small.llk-admin-stat-card__trend +2.1% so với hôm qua
      .llk-admin-stat-card
        span.llk-admin-stat-card__label Doanh thu tháng #{formattedMonth}
        strong.llk-admin-stat-card__value #{monthRevenue.toLocaleString('vi-VN')} ₫
        small.llk-admin-stat-card__trend +4.5% MoM
      .llk-admin-stat-card
        span.llk-admin-stat-card__label Doanh thu năm #{currentYear}
        strong.llk-admin-stat-card__value #{yearRevenue.toLocaleString('vi-VN')} ₫
        small.llk-admin-stat-card__trend +12.3% YoY
      .llk-admin-stat-card
        span.llk-admin-stat-card__label Tỷ lệ chuyển đổi
        strong.llk-admin-stat-card__value #{stats.conversionRate || '3.42%'}
        small.llk-admin-stat-card__trend.text-success +0.8%

    .llk-admin-dashboard__grid
      .llk-admin-chart-card
        .llk-admin-chart-card__header
          h3.heading-tertiary Revenue Overview
        pre#dashboardRevenueData(style='display:none') !{JSON.stringify(revenueData)}
        .chart-wrapper
          canvas#monthlyChart
      .llk-admin-chart-card
        .llk-admin-chart-card__header
          h3.heading-tertiary Profit vs Expenses
        pre#dashboardDailyRevenueData(style='display:none') !{JSON.stringify(dailyRevenueByMonth)}
        .chart-wrapper
          canvas#dailyChart

    .llk-admin-dashboard__two-col
      .llk-admin-table-card
        h3.heading-tertiary Recent Orders
        ul.llk-admin-table
          each order in stats.recentOrders || []
            li
              span
                strong= order.customer
                br
                small= order.note
              span
                strong= order.amount
                br
                small.status-label= order.status
          if !stats.recentOrders || !stats.recentOrders.length
            li
              span Chưa có dữ liệu
      .llk-admin-table-card
        h3.heading-tertiary Top Products
        ul.llk-admin-table
          each product in stats.topProducts || []
            li
              span
                strong= product.name
                br
                small= product.sales + ' sales'
              span
                strong= product.revenue
                br
                small.text-success +#{product.growth}%
          if !stats.topProducts || !stats.topProducts.length
            li
              span Chưa có dữ liệu

    .llk-admin-panel__toolbar
      a.btn.btn--small.btn--blue(href='/admin/tours') Quản lý tour
      a.btn.btn--small.btn--blue(href='/admin/users') Quản lý người dùng
      a.btn.btn--small.btn--blue(href='/admin/bookings') Theo dõi bookings

block scripts
  script(src='/js/dashboard.js')
