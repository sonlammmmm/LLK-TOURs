extends base

block content
  main.main
    .user-view
      nav.user-view__menu
        ul.side-nav
          li
            a(href='/me')
              svg
                use(xlink:href='/img/icons.svg#icon-user')
              | Hồ sơ
          li
            a.active(href='/chat')
              svg
                use(xlink:href='/img/icons.svg#icon-message-square')
              | Chat với Admin

      .user-view__content
        .user-view__form-container
          h2.heading-secondary.ma-bt-md Chat với Admin
          #chat-box.chat-box
          form#chat-user-form.chat-form
            input#chat-user-input(type='text', placeholder='Nhập tin nhắn...' autocomplete='off')
            button.btn.btn--blue(type='submit') 
              svg
                use(xlink:href='/img/icons.svg#icon-send')
              | Gửi

append scripts
  script.
    window.adminId = '#{admin._id}';
    window.adminName = '#{admin.name}';
    window.chatMessages = !{JSON.stringify(messages)};
  script(defer src="/js/chatUser.js")

