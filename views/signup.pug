extends base
include _authShowcase

block content
  main.main.auth-page
    section.auth-layout
      .auth-panel
        .auth-panel__inner
          .auth-brand
            a.auth-brand__logo(href='/')
              img(src='/img/logo-blue.png' alt='LLK Travel logo')
            .auth-brand__text
              span LLK Travel
              small LỮ HÀNH - KHÁM PHÁ - KẾT NỐI
          h1.auth-panel__title Khởi tạo tài khoản
          form.form.form--signup
            .auth-field
              label.auth-field__label(for='name') Họ và tên
              .auth-field__input
                i.fa-regular.fa-user
                input#name(type='text', placeholder='Trần Sỷ Sơn Lâm', required)
            .auth-field
              label.auth-field__label(for='email') Email
              .auth-field__input
                i.fa-regular.fa-envelope
                input#email(type='email', placeholder='email@llk.travel', required)
            .auth-field
              label.auth-field__label(for='password') Mật khẩu
              .auth-field__input
                i.fa-solid.fa-lock
                input#password(type='password', placeholder='Ít nhất 8 ký tự', required, minlength='8')
            .auth-field
              label.auth-field__label(for='password-confirm') Xác nhận mật khẩu
              .auth-field__input
                i.fa-solid.fa-lock
                input#password-confirm(type='password', placeholder='Nhập lại mật khẩu', required, minlength='8')
            button.btn.auth-btn(type='submit') Tạo tài khoản
          .auth-meta
            span Đã có tài khoản?
            a.auth-link(href='/login') Đăng nhập
      +authShowcase()
