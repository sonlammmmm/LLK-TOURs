extends adminLayout

block adminContent
  .llk-admin-topbar
    .llk-admin-topbar__left
      h1.llk-admin-topbar__title Quản lý khuyến mãi
      p.llk-admin-topbar__subtitle Theo dõi mã giảm giá và ưu đãi đang chạy.
    .llk-admin-topbar__right
      a.btn.btn--small.btn--green(href='/admin/promotions/new') Tạo khuyến mãi mới

  section.llk-admin-panel
    if !promotions || promotions.length === 0
      p.llk-admin-empty Chưa có chương trình khuyến mãi nào.
    else
      .promo-card-grid
        each promo in promotions
          - const isActive = promo.status === 'active';
          - const discountLabel = promo.discountType === 'percent' ? `${promo.discountValue}%` : `${promo.discountValue.toLocaleString('vi-VN')} VND`;
          - const startLabel = promo.startDate ? new Date(promo.startDate).toLocaleDateString('vi-VN') : 'Không xác định';
          - const endLabel = promo.endDate ? new Date(promo.endDate).toLocaleDateString('vi-VN') : 'Không giới hạn';
          article.promo-card
            .promo-card__head
              .promo-card__title
                span.promo-card__code= promo.code
                h3.promo-card__name= promo.name
                if promo.description
                  p.promo-card__desc= promo.description
              span(class=`promo-card__badge ${isActive ? 'promo-card__badge--active' : 'promo-card__badge--inactive'}`)= isActive ? 'Đang hoạt động' : 'Đã dừng'
            .promo-card__meta
              p
                strong Ưu đãi:
                |  #{discountLabel}
                if promo.maxDiscountAmount
                  span.promo-card__chip= `Tối đa ${promo.maxDiscountAmount.toLocaleString('vi-VN')} VND`
              p
                strong Hiệu lực:
                |  #{startLabel} - #{endLabel}
              p
                strong Giới hạn:
                |  #{promo.usageLimit ? promo.usageLimit : 'Không giới hạn'} lượt
            .promo-card__actions
              a.btn.btn--small.btn--blue(href=`/admin/promotions/${promo.id}/edit`) Chỉnh sửa
              a.btn.btn--small.btn--orange(href=`/admin/promotions/${promo.id}/assign`) Gán mã
              button.btn.btn--small.btn--red.btn-delete-promotion(data-promo-id=`${promo.id}`) Xóa



