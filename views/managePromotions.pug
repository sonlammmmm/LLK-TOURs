extends adminLayout

block adminContent
  .llk-admin-topbar
    .llk-admin-topbar__left
      h1.llk-admin-topbar__title Quản lý khuyến mãi
      p.llk-admin-topbar__subtitle Theo dõi mã giảm giá và ưu đãi đang chạy.
    .llk-admin-topbar__right
      a.btn.btn--small.btn--green(href='/admin/promotions/new') Tạo khuyến mãi mới

  section.llk-admin-panel
    if !promotions || promotions.length === 0
      p.llk-admin-empty Chưa có chương trình khuyến mãi nào.
    else
      .promotion-table
        table
          thead
            tr
              th Tên / Mã
              th Ưu đãi
              th Hiệu lực
              th Trạng thái
              th Thao tác
          tbody
            each promo in promotions
              tr
                td
                  strong= `${promo.name} (${promo.code})`
                  if promo.description
                    p.table-desc= promo.description
                td
                  if promo.discountType === 'percent'
                    span= `${promo.discountValue}%`
                  else
                    span= `${promo.discountValue.toLocaleString('vi-VN')} ₫`
                  if promo.maxDiscountAmount
                    span.badge.badge--neutral= `Tối đa ${promo.maxDiscountAmount.toLocaleString('vi-VN')} ₫`
                td
                  span= promo.startDate ? new Date(promo.startDate).toLocaleDateString('vi-VN') : 'N/A'
                  |  -
                  span= promo.endDate ? new Date(promo.endDate).toLocaleDateString('vi-VN') : 'Không giới hạn'
                td
                  span(class=`badge ${promo.status === 'active' ? 'badge--green' : 'badge--gray'}`)= promo.status
                td
                  .table-actions
                    a.btn.btn--small.btn--blue(href=`/admin/promotions/${promo.id}/edit`) Chỉnh sửa
                    a.btn.btn--small.btn--orange(href=`/admin/promotions/${promo.id}/assign`) Gán mã
                    button.btn.btn--small.btn--red.btn-delete-promotion(data-promo-id=`${promo.id}`) Xóa

block append scripts
  script(src='/js/promotionManagement.js', type='module')
