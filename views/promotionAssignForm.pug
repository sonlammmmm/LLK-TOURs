extends adminLayout

block adminContent
  .llk-admin-topbar
    .llk-admin-topbar__left
      h1.llk-admin-topbar__title Gắn mã cho user
      p.llk-admin-topbar__subtitle Phát hành mã và giới hạn lượt theo từng tài khoản.
    .llk-admin-topbar__right
      a.btn.btn--ghost(href='/admin/promotions') Quay lại danh sách khuyến mãi

  section.llk-admin-panel
    .llk-admin-panel__header
      .llk-admin-panel__header-title
        h2.heading-secondary Gắn mã #{promotion.code}
        p.llk-admin-panel__header-subtitle #{promotion.name}
      .llk-admin-panel__stats
        .llk-admin-stat-card
          span.llk-admin-stat-card__label Loại ưu đãi
          strong.llk-admin-stat-card__value
            if promotion.discountType === 'percent'
              | Giảm #{promotion.discountValue}%
            else
              | #{promotion.discountValue.toLocaleString('vi-VN')} VND
        .llk-admin-stat-card
          span.llk-admin-stat-card__label Trạng thái
          strong.llk-admin-stat-card__value
            = promotion.status === 'active' ? 'Đang hoạt động' : 'Tạm ngưng'

    form.form.form-assign-promotion
      input(type='hidden', id='assign-promotion-id', value=promotion.id)
      .llk-admin-form-grid
        .llk-admin-form-card
          h3.heading-tertiary Chọn người dùng
          .form__group
            label.form__label(for='assign-user') Người dùng
            select#assign-user.form__select(name='assign-user' multiple size='6')
              option(value='' disabled selected)= '-- Chọn user --'
              each user in users
                option(value=user.id)= `${user.name} (${user.email})`
            small.form__hint Giữ Ctrl (Cmd trên Mac) để chọn nhiều người cùng lúc.
        .llk-admin-form-card
          h3.heading-tertiary Cài đặt áp dụng mã
          .form__group
            label.form__label(for='assign-limit') Số lượt tối đa mỗi user
            input#assign-limit.form__input(type='number', min='1', value=promotion.perUserLimit || 1)
          .form__group
            label.form__label(for='assign-expiry') Hạn dùng (nếu cần)
            input#assign-expiry.form__input(type='date')
          .form__group
            label.form__label(for='assign-note') Ghi chú
            textarea#assign-note.form__textarea(rows='3')
          .form__group
            button.btn.btn--green.btn-assign-promotion(type='submit') Gắn mã cho user
