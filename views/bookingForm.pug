extends base

block content
  main.main
    .booking-container
      .booking-card
        h2.hd-secondary Đặt tour

        // ==== THÔNG TIN TOUR COMPACT ====
        .booking-details
          .booking-image
            img(src=`/img/tours/${tour.imageCover}`, alt=`${tour.name}`)
          
          .booking-info
            h3.booking-title= tour.name
            .booking-meta
              .booking-meta-item
                svg.booking-icon
                  use(xlink:href='/img/icons.svg#icon-clock')
                span= `${tour.duration} ngày`
              .booking-meta-item
                svg.booking-icon
                  use(xlink:href='/img/icons.svg#icon-map-pin')
                span= tour.startLocation.description
              .booking-meta-item
                svg.booking-icon
                  use(xlink:href='/img/icons.svg#icon-calendar')
                span Nhiều ngày khởi hành
              .booking-meta-item
                svg.booking-icon
                  use(xlink:href='/img/icons.svg#icon-user')
                span= `Tối đa ${tour.maxGroupSize} người`

        // ==== FORM ĐẶT TOUR - LAYOUT 2 CỘT ====
        form.booking-main-form
          input(type="hidden", name="tourId", value=`${tour._id}`)
          input#selectedDate(type="hidden", name="startDate", value="")

          // CỘT TRÁI: CHỌN NGÀY & SỐ NGƯỜI
          .booking-left-col
            
            // --- CHỌN NGÀY KHỞI HÀNH ---
            .booking-section
              label.booking-section-label
                span.booking-step-number 1
                span Chọn ngày khởi hành:
              
              if tour.startDates && tour.startDates.length > 0
                - var today = new Date();
                - today.setHours(0, 0, 0, 0);
                - var availableDates = tour.startDates.filter(sd => new Date(sd.date) >= today && sd.availableSlots > 0);
                
                if availableDates.length > 0
                  .booking-date-grid
                    each startObj in availableDates
                      - var dateObj = new Date(startObj.date);
                      - var day = dateObj.getDate();
                      - var month = dateObj.toLocaleDateString('vi-VN', { month: 'short' });
                      - var year = dateObj.getFullYear();
                      - var weekday = dateObj.toLocaleDateString('vi-VN', { weekday: 'short' });
                      - var lowSlots = startObj.availableSlots <= 3;
                      
                      .booking-date-btn(
                        class=lowSlots ? 'low-slots' : '',
                        data-date=dateObj.toISOString(),
                        data-slots=startObj.availableSlots
                      )
                        .booking-date-day= day
                        .booking-date-month= `${month} ${year}`
                        .booking-date-weekday= weekday
                        .booking-date-slots= `${startObj.availableSlots} chỗ`
                else
                  .booking-no-dates Không có ngày khởi hành khả dụng
              else
                .booking-no-dates Không có ngày khởi hành khả dụng

            // --- SỐ LƯỢNG NGƯỜI ---
            .booking-section
              label.booking-section-label
                span.booking-step-number 2
                span Số lượng người tham gia:
              
              .booking-participants-ctrl
                button.booking-participants-btn.decrease-btn(type="button") −
                .booking-participants-display
                  .booking-participants-num#participants-number 1
                  .booking-participants-text người
                button.booking-participants-btn.increase-btn(type="button") +
              
              input#participants-input(type="hidden", name="participants", value="1")

          // CỘT PHẢI: THANH TOÁN
          .booking-right-col
            

            .booking-payment-card
              - var serviceStep = services && services.length ? 4 : 3;
              h3.booking-payment-title Chi tiết thanh toán
              .booking-payment-row
                .booking-payment-label Giá tour:
                .booking-payment-value#price-per-person= `${tour.price.toLocaleString('vi-VN')} ₫`
              .booking-payment-row
                .booking-payment-label Số người:
                .booking-payment-value#participants-display 1
              if services && services.length
                .booking-section.booking-services
                  label.booking-section-label
                    span.booking-step-number 3
                    span Chọn dịch vụ thêm:
                  .services-list
                    each service in services
                      .service-item
                        label.service-card
                          input.service-checkbox(type="checkbox", data-service-id=service.id, data-price=service.price, data-charge-type=service.chargeType, data-allow-multiple=service.allowMultiple, data-max-quantity=service.maxQuantity, data-min-quantity=service.minQuantity, data-name=service.name)
                          .service-card__content
                            .service-card__head
                              .service-card__title= service.name
                              span.service-card__price= `${service.price.toLocaleString('vi-VN')} ₫`
                            if service.shortDescription
                              .service-card__desc= service.shortDescription
                            .service-card__meta
                              span.badge.badge--neutral= service.chargeType === 'per-person' ? 'Tính theo người' : 'Tính theo lượt'
                            if service.allowMultiple && service.chargeType === 'per-booking'
                              .service-quantity
                                label(for=`service-qty-${service.id}`) Số lượng
                                input.service-quantity-input(type="number", id=`service-qty-${service.id}`, min=service.minQuantity || 1, max=service.maxQuantity || service.minQuantity || 1, value=service.minQuantity || 1, data-service-id=service.id, disabled)
              .booking-payment-row
                .booking-payment-label Tổng dịch vụ:
                .booking-payment-value#services-total 0 ₫
              .booking-payment-row
                .booking-payment-label Giảm giá:
                .booking-payment-value#discount-amount 0 ₫
              .booking-payment-row.total-row
                .booking-payment-label Tổng cộng:
                .booking-payment-value#grand-total= `${tour.price.toLocaleString('vi-VN')} ₫`
              .booking-section
                label.booking-section-label
                  span.booking-step-number #{serviceStep}
                  span Áp mã khuyến mãi:
                .promotion-actions
                  input#promotion-code(type="text", placeholder="Nhập mã khuyến mãi" autocomplete="off")
                  button.btn.btn--small.btn--blue#apply-promo(type="button") Áp dụng
                  button.btn.btn--small.btn--gray#remove-promo(type="button", disabled=true, hidden) Xóa mã
                p.promo-message#promotion-message
                if userPromotions && userPromotions.length
                  .user-promotions-hint
                    span Có #{userPromotions.length} mã cho bạn:
                    .promo-chip-list
                      each promo in userPromotions
                        button(type="button", class="promo-chip", data-code=promo.code, data-name=promo.name, data-expiry=promo.expiresAt)= promo.code

            .booking-actions
              a.btn.btn--gray(href=`/tour/${tour.slug}`) Quay lại
              button.btn.btn--green#book-tour(
                type="button",
                data-tour-id=`${tour._id}`,
                data-max-size=`${tour.maxGroupSize}`,
                data-price=`${tour.price}`,
                disabled
              ) Thanh toán ngay

block scripts
  -
    const bookingDataPayload = JSON.stringify({
      services: services || [],
      userPromotions: userPromotions || []
    });
  script#booking-data(type='application/json')!= bookingDataPayload
  script(src="/js/bookingForm.js", type="module")
  script(src="/js/stripe.js", type="module")
