extends base

block content
  -
    const ratingValue =
      typeof tour.ratingsAverage === 'number'
        ? tour.ratingsAverage.toFixed(1)
        : '4.5';
    const reviewCount = tour.ratingsQuantity || 0;
    const locationDescription =
      tour.startLocation && tour.startLocation.description
        ? tour.startLocation.description
        : 'Đang cập nhật';
    const highlightSummary =
      tour.summary ||
      'Lên đường cùng LLK Travel với lịch trình linh hoạt, lưu trú chất lượng và đội ngũ hỗ trợ 24/7.';
    const maxGroup = tour.maxGroupSize || 1;
    const basePrice = Number(tour.price) || 0;
    const formattedPrice = basePrice.toLocaleString('vi-VN');
    const primaryImage = tour.imageCover || 'tour-default.jpg';
    const tourDuration = Number(tour.duration) || 0;
    let availableDates = [];
    if (tour.startDates && tour.startDates.length > 0) {
      const now = new Date();
      now.setHours(0, 0, 0, 0);
      availableDates = tour.startDates.filter(sd => {
        const d = new Date(sd.date);
        return d >= now && (sd.availableSlots || 0) > 0;
      });
    }

  main.main.booking-shell
    form.booking-workspace(novalidate)
      input(type='hidden', name='tourId', value=`${tour._id}`)
      input#selectedDate(type='hidden', name='startDate', value='')
      input#participants-input(type='hidden', name='participants', value='1')

      .booking-layout-grid
        section.booking-card.booking-card--tour
          .tour-card
            .tour-card__media
              img(src=`/img/tours/${primaryImage}`, alt=`${tour.name}`)
            .tour-card__body
              span.tour-card__badge= locationDescription
              h1.tour-card__title= tour.name
              p.tour-card__summary= highlightSummary
              ul.tour-card__meta
                li
                  span.label Thời lượng
                  span.value= `${tourDuration} ngày`
                li
                  span.label Đánh giá
                  span.value= `${ratingValue}/5 (${reviewCount})`
                li
                  span.label Số khách tối đa
                  span.value= `${maxGroup} khách`

        .booking-action-panel
        .booking-action-panel
          section.booking-card.booking-card--dates
              .booking-card__header
                h2 Chọn ngày khởi hành
                p.card-desc Các ngày hiển thị đều còn chỗ trống
              if availableDates.length
                .booking-date-grid
                  each startObj in availableDates
                    - const dateObj = new Date(startObj.date)
                    - const day = dateObj.getDate()
                    - const month = dateObj.toLocaleDateString('vi-VN', { month: 'short' })
                    - const year = dateObj.getFullYear()
                    - const weekday = dateObj.toLocaleDateString('vi-VN', { weekday: 'short' })
                    - const lowSlots = startObj.availableSlots <= 3
                    button.booking-date-btn(
                      type='button',
                      class=lowSlots ? 'low-slots' : '',
                      data-date=dateObj.toISOString(),
                      data-slots=startObj.availableSlots
                    )
                      span.booking-date-weekday= weekday
                      strong.booking-date-day= day
                      span.booking-date-month= `${month} ${year}`
                      span.booking-date-slotline= `${startObj.availableSlots} chỗ`
                      if lowSlots
                        span.booking-date-alert Sắp hết
              else
                .booking-empty-state Chưa có lịch khởi hành mở. Quay lại sau bạn nhé.
              .booking-date-selected
                .booking-date-selected__info
                  span.booking-date-selected__label Ngày đã chọn
                  strong#selected-date-label Chưa chọn
                span.booking-date-slots#selected-date-slots Chưa xác định

          if services && services.length
            section.booking-card.booking-card--services
              .booking-card__header
                h2 Dịch vụ bổ sung
                p.card-desc Tùy chọn thêm để nâng cấp trải nghiệm
                .service-options
                  each service in services
                    - const serviceId = service.id || (service._id && service._id.toString())
                    .service-option
                      label.service-option__main(for=`service-check-${serviceId}`)
                        input.service-checkbox(
                          type='checkbox',
                          id=`service-check-${serviceId}`,
                          value=serviceId,
                          data-service-id=serviceId,
                          data-price=service.price,
                          data-charge-type=service.chargeType,
                          data-allow-multiple=service.allowMultiple,
                          data-min-quantity=service.minQuantity || 1,
                          data-max-quantity=service.maxQuantity || service.minQuantity || 1,
                          data-name=service.name
                        )
                        .service-option__details
                          strong= service.name
                          span.service-option__price= `${service.price.toLocaleString('vi-VN')} đ`
                          if service.shortDescription
                            p.service-option__desc= service.shortDescription
                          .service-option__badges
                            span.badge= service.chargeType === 'per-person' ? 'Theo khách' : 'Theo booking'
                            if service.allowMultiple && service.chargeType === 'per-booking'
                              span.badge.badge--outline Nhiều lần
                      if service.allowMultiple && service.chargeType === 'per-booking'
                        .service-quantity
                          label.service-quantity__label(for=`service-qty-${serviceId}`) Số lượng
                          input.service-quantity-input(
                            type='number',
                            id=`service-qty-${serviceId}`,
                            min=service.minQuantity || 1,
                            max=service.maxQuantity || service.minQuantity || 1,
                            value=service.minQuantity || 1,
                            data-service-id=serviceId,
                            disabled
                          )
          else
            section.booking-card.booking-card--services
              .booking-card__header
                h2 Dịch vụ bổ sung
                p.card-desc Chưa có dịch vụ bổ sung cho tour này
              .booking-empty-state Bạn vẫn có thể đặt tour ngay.

          section.booking-card.booking-card--payment
              .booking-card__header
                h2 Thanh toán
                p.card-desc Kiểm tra chi phí dự kiến trước khi thanh toán
              .payment-card
                .payment-row
                  span.payment-label Giá tour / khách
                  span.payment-value#price-per-person= `${formattedPrice} đ`
                .payment-row
                  span.payment-label Số người
                  span.payment-value#participants-display 1
                .payment-row
                  span.payment-label Dịch vụ bổ sung
                  span.payment-value#services-total 0 đ
                .payment-row
                  span.payment-label Giảm giá
                  span.payment-value#discount-amount 0 đ
                .payment-row.total-row
                  span.payment-label Tổng thanh toán dự kiến
                  span.payment-value#grand-total= `${formattedPrice} đ`

              section.booking-card.booking-card--participants-insight
                h3 Số lượng khách
                p.card-desc Điều chỉnh để hệ thống tính chi phí chính xác.
                .participants-control
                  button.booking-participants-btn.decrease-btn(type='button', aria-label='Giảm số lượng') -
                  .participants-count
                    span Nhóm khách
                    strong#participants-number 1
                  button.booking-participants-btn.increase-btn(type='button', aria-label='Tăng số lượng') +
                .participants-hint
                  span.text Còn
                  strong#participants-remaining= `${Math.max(maxGroup - 1, 0)} chỗ`
                  span.text= `trống / tối đa ${maxGroup} khách`

              .promotion-block
                label(for='promotion-code') Mã ưu đãi
                .promotion-actions
                  input#promotion-code(type='text', placeholder='Nhập mã của bạn', autocomplete='off')
                  button.btn.btn--small.btn--blue#apply-promo(type='button') Áp dụng
                  button.btn.btn--small.btn--gray#remove-promo(type='button', disabled=true, hidden) Xoá mã
                p.promo-message#promotion-message
                if userPromotions && userPromotions.length
                  .promo-chip-list
                    each promo in userPromotions
                      button(type='button', class='promo-chip', data-code=promo.code, data-name=promo.name, data-expiry=promo.expiresAt)= promo.code

              .booking-actions
                a.btn.btn--gray(href=`/tour/${tour.slug}`) Xem thông tin tour
                button.btn.btn--green#book-tour(
                  type='button',
                  data-tour-id=`${tour._id}`,
                  data-max-size=`${maxGroup}`,
                  data-price=`${basePrice}`,
                  disabled=true
                ) Thanh toán Stripe

block scripts
  -
    const serializedServices = (services || []).map(service => ({
      id: service.id || (service._id && service._id.toString()),
      name: service.name,
      price: service.price,
      chargeType: service.chargeType,
      allowMultiple: service.allowMultiple,
      minQuantity: service.minQuantity,
      maxQuantity: service.maxQuantity,
      shortDescription: service.shortDescription,
      description: service.description
    }));
    const bookingDataPayload = JSON.stringify({
      services: serializedServices,
      userPromotions: userPromotions || []
    });
  script#booking-data(type='application/json')!= bookingDataPayload
  script(src='/js/bookingForm.js', type='module')
  script(src='/js/stripe.js', type='module')
