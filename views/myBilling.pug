extends base
include _userPortalMenu

block content
  main.main.user-portal-instance
    section.user-portal
      +userPortalMenu('billing')
      .user-portal__content
        .user-portal__content-heading
          h2.heading-secondary Hoá đơn & thanh toán
          p Theo dõi mọi giao dịch, trạng thái và in hoá đơn cần thiết chỉ trong vài thao tác.

        .billing-panel
          .billing-filter
            input.billing-search(type='text', placeholder='Tìm hoá đơn...')
            select.billing-status
              option(value='') Tất cả trạng thái
              option(value='paid') Đã thanh toán
              option(value='unpaid') Chưa thanh toán

          .billing-list
            if bookings.length === 0
              .billing-empty.empty-tours
                h2.heading-secondary Bạn chưa có hoá đơn nào
                p.empty-tours-text Khi đặt tour thành công, hoá đơn sẽ hiển thị tại đây.
                a.my-tour-link(href='/all') Khám phá tour
            else
              each booking in bookings
                .billing-item
                  .billing-item__header
                    .billing-item__tour= booking.tour.name
                    .billing-item__date
                      span= new Date(booking.createdAt).toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' })
                      span.billing-item__id ##{booking.id.slice(-8).toUpperCase()}

                  .billing-item__details
                    .billing-item__info
                      .billing-item__label Số lượng người:
                      .billing-item__value= booking.participants
                    .billing-item__info
                      .billing-item__label Tổng tiền:
                      .billing-item__value= `${booking.price.toLocaleString('vi-VN')} VND`
                    .billing-item__info
                      .billing-item__label Trạng thái:
                      .billing-item__value
                        span(class=`billing-status billing-status--${booking.paid ? 'paid' : 'unpaid'}`)= booking.paid ? 'Đã thanh toán' : 'Chưa thanh toán'

                  .billing-item__actions
                    a.btn.btn--small.btn--green(href=`/booking-invoice/${booking.id}`) Xem hoá đơn
