extends base

block content
  main.main
    .booking-success
      if pending
        //- ĐANG CHỜ XÁC NHẬN
        .booking-success__pending
          .booking-success__spinner
            svg.spinner
              circle(cx="50" cy="50" r="45")
          h2.hd-secondary Đang xác nhận thanh toán...
          p.booking-success__message Vui lòng đợi trong giây lát, chúng tôi đang xử lý booking của bạn.
          p.booking-success__note Không đóng trang này.
      else
        //- ĐÃ XÁC NHẬN THÀNH CÔNG
        .booking-success__confirmed
          .booking-success__icon
            svg.checkmark
              use(xlink:href='/img/icons.svg#icon-check')
          
          h2.hd-secondary Thanh toán thành công! 🎉
          p.booking-success__message Cảm ơn bạn đã đặt tour. Chúng tôi đã gửi email xác nhận đến hộp thư của bạn.

          if booking
            .booking-success__details
              h3 Thông tin booking:
              
              .booking-detail-row
                strong Tour:
                span= booking.tour.name
              
              .booking-detail-row
                strong Ngày khởi hành:
                span= new Date(booking.startDate).toLocaleDateString('vi-VN')
              
              .booking-detail-row
                strong Số người:
                span= `${booking.participants} người`

              if booking.services && booking.services.length
                .booking-detail-row
                  strong Dịch vụ thêm:
                  ul.booking-services
                    each service in booking.services
                      li
                        span= `${service.name} x ${service.quantity}`
                        span.booking-services__price= `${(service.total || 0).toLocaleString('vi-VN')} ₫`

              if booking.discountAmount && booking.discountAmount > 0
                .booking-detail-row
                  strong Giảm giá:
                  span= `- ${(booking.discountAmount || 0).toLocaleString('vi-VN')} ₫`

              .booking-detail-row
                strong Tổng thanh toán:
                span= `${booking.price.toLocaleString('vi-VN')} ₫`
              
              .booking-detail-row
                strong Trạng thái:
                span.status-badge.status-badge--paid= booking.paid ? 'Đã thanh toán' : 'Chưa thanh toán'

          .booking-success__actions
            a.btn.btn--green(href='/my-tours') Xem tour của tôi
            a.btn.btn--gray(href='/') Quay về trang chủ

block scripts
  if pending && sid
    script(src='/js/bookingSuccess.js')